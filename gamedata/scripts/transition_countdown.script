local MOD_ID = "transition_countdown"

pcall(require, "transition_countdown_adaptation")
pcall(require, "transition_countdown_user_config")

local PANEL_IMAGES = {}

local UI_W = 1024
local UI_H = 768

local BASE_PANEL_H = 310
local TIMER_BASE_WIDTH = 220
local TIMER_BASE_HEIGHT = 50
local KEY_SEND_NOW_BASE_WIDTH = 520
local KEY_SEND_NOW_BASE_HEIGHT = 50
local CUSTOM_LABEL_COUNT = 3
local CUSTOM_LABEL_BASE_WIDTH = 620
local CUSTOM_LABEL_BASE_HEIGHT = 50

local TEXT_SIZE_MIN_PERCENT = 20
local TEXT_SIZE_MAX_PERCENT = 300
local TEXT_SIZE_LEVEL_COUNT = TEXT_SIZE_MAX_PERCENT

local IMAGE_SCALE_MIN = 0.05
local IMAGE_SCALE_MAX = 3.0

local DEFAULT_FONT_FAMILY_NAME = "Pizza Hut Font PE"

local defaults = {
    enabled = true,

    duration = 7.4,

    group_x = 0,
    group_y = 0,

    fade_time = 1.5,

    image_index = 0,
    image_x = 0,
    image_y = 0,
    image_alpha = 95,
    image_r = 255,
    image_g = 255,
    image_b = 255,
    image_scale = 1.0,

    success_image_index = 0,
    success_image_x = 0,
    success_image_y = 0,
    success_image_alpha = 95,
    success_image_r = 255,
    success_image_g = 255,
    success_image_b = 255,
    success_image_scale = 1.0,

    timer_x = 0,
    timer_y = 0,
    timer_alpha = 95,
    timer_r = 224,
    timer_g = 224,
    timer_b = 224,
    timer_font_family = 8,
    timer_font_variant = 0,
    timer_size = 100,
    decimals = true,

    key_send_now = 28,
    key_send_now_x = 0,
    key_send_now_y = 0,
    key_send_now_alpha = 95,
    key_send_now_r = 224,
    key_send_now_g = 224,
    key_send_now_b = 224,
    key_send_now_font_family = 8,
    key_send_now_font_variant = 0,
    key_send_now_size = 100,

    custom_label_1 = "",
    custom_label_1_x = 0,
    custom_label_1_y = 0,
    custom_label_1_alpha = 95,
    custom_label_1_r = 224,
    custom_label_1_g = 224,
    custom_label_1_b = 224,
    custom_label_1_font_family = 8,
    custom_label_1_font_variant = 0,
    custom_label_1_size = 100,

    custom_label_2 = "",
    custom_label_2_x = 0,
    custom_label_2_y = 0,
    custom_label_2_alpha = 95,
    custom_label_2_r = 224,
    custom_label_2_g = 224,
    custom_label_2_b = 224,
    custom_label_2_font_family = 8,
    custom_label_2_font_variant = 0,
    custom_label_2_size = 100,

    custom_label_3 = "",
    custom_label_3_x = 0,
    custom_label_3_y = 0,
    custom_label_3_alpha = 95,
    custom_label_3_r = 224,
    custom_label_3_g = 224,
    custom_label_3_b = 224,
    custom_label_3_font_family = 8,
    custom_label_3_font_variant = 0,
    custom_label_3_size = 100,
}

local patched_inits = {}
local patched_init_controls = {}
local patch_started = false
local patch_attempts = 0
local key_callback_registered = false
local active = nil
local retry_session = nil
local STAC_CONFIG_GUI = nil
local STAC_CONFIG_PREVIEW = nil
local font_atlas_cache = {}
local font_catalog_loaded = false
local image_catalog_loaded = false
local user_config_loaded = false
local user_config_dirty = false
local user_config_callback_registered = false
local user_config_save_pending = false
local user_config_changed_at = 0
local normalize_text_size_settings
local normalize_font_variant_settings

local FONT_FAMILIES = {}

local function get_ttf_runtime()
    local ok, runtime = pcall(function() return transition_countdown_ttf_and_otf_runtime end)
    if ok and type(runtime) == "table" and runtime.is_ready then return runtime end
    return nil
end

local function load_runtime_font_catalog(force_refresh)
    if font_catalog_loaded and not force_refresh and #FONT_FAMILIES > 0 then return true end

    local runtime = get_ttf_runtime()
    if not (runtime and runtime.get_font_catalog) then return false end

    local ok, catalog = pcall(runtime.get_font_catalog, force_refresh == true)
    if not ok or type(catalog) ~= "table" or #catalog == 0 then return false end

    FONT_FAMILIES = catalog
    font_catalog_loaded = true
    return true
end

local function set_default_font_family_settings()
    load_runtime_font_catalog(false)
    local default_index = 0
    for index, family in ipairs(FONT_FAMILIES) do
        if family.name == DEFAULT_FONT_FAMILY_NAME then
            default_index = index - 1
            break
        end
    end

    defaults.timer_font_family = default_index
    defaults.key_send_now_font_family = default_index
    for index = 1, CUSTOM_LABEL_COUNT do
        defaults["custom_label_" .. tostring(index) .. "_font_family"] = default_index
    end
end

local function load_runtime_images(force_refresh)
    if image_catalog_loaded and not force_refresh and #PANEL_IMAGES > 0 then return true end

    local runtime = get_ttf_runtime()
    if not (runtime and runtime.get_image_catalog) then
        PANEL_IMAGES = {}
        image_catalog_loaded = false
        return false
    end

    local ok, catalog = pcall(runtime.get_image_catalog, force_refresh == true)
    if not ok or type(catalog) ~= "table" or #catalog == 0 then
        PANEL_IMAGES = {}
        image_catalog_loaded = false
        return false
    end

    PANEL_IMAGES = catalog
    image_catalog_loaded = true
    return true
end

local function get_font_variant_key_for_font_key(font_key)
    if font_key == "timer_font_family" then return "timer_font_variant" end
    if font_key == "key_send_now_font_family" then return "key_send_now_font_variant" end
    for index = 1, CUSTOM_LABEL_COUNT do
        if font_key == "custom_label_" .. tostring(index) .. "_font_family" then
            return "custom_label_" .. tostring(index) .. "_font_variant"
        end
    end
    return "timer_font_variant"
end

local function can_render_dynamic_text(family, variant_index)
    if not family then return false end
    local runtime = get_ttf_runtime()
    if not runtime or not runtime.can_render_family then return false end
    local ok, result = pcall(runtime.can_render_family, family, variant_index)
    return ok and result == true
end

local function mcm_path(key)
    local key_text = tostring(key)
    if string.find(key_text, "/", 1, true) then return MOD_ID .. "/" .. key_text end
    return MOD_ID .. "/main/" .. key_text
end

local function getv(key)
    if ui_mcm and ui_mcm.get then
        local ok, v = pcall(ui_mcm.get, mcm_path(key))
        if ok and v ~= nil then return v end
    end
    return defaults[key]
end

local function get_bool(key)
    local v = getv(key)
    return v == true or v == 1 or v == "1" or v == "true"
end

local function is_tenth_step_setting(key)
    local key_text = tostring(key or "")
    return key_text == "duration"
        or key_text == "fade_time"
        or string.sub(key_text, -9) == "_duration"
end

local function normalize_tenth_step(value)
    local number = tonumber(value)
    if number == nil then return nil end
    if number >= 0 then
        return math.floor(number * 10 + 0.5) / 10
    end
    return math.ceil(number * 10 - 0.5) / 10
end

local function get_num(key)
    local v = tonumber(getv(key))
    if v == nil then return tonumber(defaults[key]) or 0 end
    if is_tenth_step_setting(key) then return normalize_tenth_step(v) end
    return v
end

local function append_adaptation_defaults()
    local adaptation = transition_countdown_adaptation
    if adaptation and adaptation.append_defaults then
        pcall(adaptation.append_defaults, defaults)
    end
end

local function trim_text(value)
    return tostring(value or ""):gsub("^%s+", ""):gsub("%s+$", "")
end

local MCM_TEXT_STORAGE_PREFIX = "TCHEX2_"

local function is_custom_label_key(key)
    return key == "custom_label_1" or key == "custom_label_2" or key == "custom_label_3"
end

local function encode_custom_label_storage(value)
    local source = tostring(value or "")
    local out = { MCM_TEXT_STORAGE_PREFIX }
    for index = 1, #source do
        out[#out + 1] = string.format("%02X", string.byte(source, index))
    end
    return table.concat(out)
end

local function decode_custom_label_storage(value)
    local source = tostring(value or "")

    local payload
    if string.sub(source, 1, #MCM_TEXT_STORAGE_PREFIX) == MCM_TEXT_STORAGE_PREFIX then
        payload = string.sub(source, #MCM_TEXT_STORAGE_PREFIX + 1)
    else
        return source
    end

    if (#payload % 2) ~= 0 or string.find(payload, "[^0-9A-Fa-f]") then
        return source
    end

    local out = {}
    for index = 1, #payload, 2 do
        local byte_value = tonumber(string.sub(payload, index, index + 1), 16)
        if byte_value == nil then return source end
        out[#out + 1] = string.char(byte_value)
    end
    return table.concat(out)
end

local function read_custom_label_storage(index)
    local key = "custom_label_" .. tostring(index)
    local raw = nil
    if axr_main and axr_main.config and axr_main.config.r_value then
        local ok, value = pcall(axr_main.config.r_value, axr_main.config, "mcm", mcm_path(key), 0, defaults[key])
        if ok then raw = value end
    end
    if raw == nil then raw = defaults[key] end
    return decode_custom_label_storage(raw)
end

local function mcm_custom_label_current(index)
    return read_custom_label_storage(index)
end

local function mcm_custom_label_save(index, value)
    local key = "custom_label_" .. tostring(index)
    local decoded = decode_custom_label_storage(value)
    local encoded = encode_custom_label_storage(decoded)

    if axr_main and axr_main.config and axr_main.config.w_value then
        axr_main.config:w_value("mcm", mcm_path(key), encoded)
        axr_main.config:save()
    elseif ui_mcm and ui_mcm.set then
        ui_mcm.set(mcm_path(key), encoded)
    end

end

local function get_str(key)
    local value = getv(key)
    if value == nil then value = defaults[key] end
    value = tostring(value or "")
    if is_custom_label_key(key) then
        value = decode_custom_label_storage(value)
    end
    return value
end

local function clamp(v, lo, hi)
    v = tonumber(v) or lo
    return math.max(lo, math.min(v, hi))
end

local function clamp_index(v, fallback)
    if #PANEL_IMAGES == 0 then return nil end
    v = math.floor((tonumber(v) or fallback or 0) + 0.5)
    if v < 0 then return 0 end
    if v > #PANEL_IMAGES - 1 then return #PANEL_IMAGES - 1 end
    return v
end

local function clamp_font_family_index(value)
    load_runtime_font_catalog(false)
    value = math.floor((tonumber(value) or 0) + 0.5)
    if value < 0 then return 0 end
    if value > #FONT_FAMILIES - 1 then return math.max(0, #FONT_FAMILIES - 1) end
    return value
end

local function get_font_family_by_index(value)
    load_runtime_font_catalog(false)
    return FONT_FAMILIES[clamp_font_family_index(value) + 1] or FONT_FAMILIES[1]
end

local function get_font_family_key_for_size_key(key)
    if key == "timer_size" then return "timer_font_family" end
    if key == "key_send_now_size" then return "key_send_now_font_family" end
    for index = 1, CUSTOM_LABEL_COUNT do
        if key == "custom_label_" .. tostring(index) .. "_size" then
            return "custom_label_" .. tostring(index) .. "_font_family"
        end
    end
    return "timer_font_family"
end

local function get_current_font_family(font_key)
    return get_font_family_by_index(get_num(font_key or "timer_font_family"))
end

local function get_font_family_name_by_index(value)
    local family = get_font_family_by_index(value)
    return family and family.name or "<no fonts>"
end

local function get_font_variant_count(font_key)
    local family = get_current_font_family(font_key)
    return family and family.variants and math.max(1, #family.variants) or 1
end

local function clamp_font_variant_index(value, font_key)
    value = math.floor((tonumber(value) or 0) + 0.5)
    if value < 0 then return 0 end
    local max_index = get_font_variant_count(font_key) - 1
    if value > max_index then return max_index end
    return value
end

local function get_current_font_variant_index(font_key)
    local variant_key = get_font_variant_key_for_font_key(font_key)
    return clamp_font_variant_index(get_num(variant_key), font_key)
end

local function get_font_variant_name(font_key, value)
    local family = get_current_font_family(font_key)
    if not (family and family.variants and #family.variants > 0) then return "<no variants>" end
    local index = clamp_font_variant_index(value, font_key) + 1
    local variant = family.variants[index]
    return variant and variant.name or "<no variants>"
end

local function get_font_size_count(font_key)
    local family = get_current_font_family(font_key)
    return family and family.sizes and #family.sizes or TEXT_SIZE_LEVEL_COUNT
end

local function get_image_entry_by_key(key, fallback)
    load_runtime_images()
    local index = clamp_index(get_num(key), fallback)
    return index and PANEL_IMAGES[index + 1] or nil
end

local function get_image_name_by_index(value, fallback)
    load_runtime_images()
    local index = clamp_index(value, fallback)
    local image = index and PANEL_IMAGES[index + 1] or nil
    return image and image.name or "<no images>"
end

local function panel_image_content()
    if not load_runtime_images(false) then
        load_runtime_images(true)
    end
    local result = {}
    for index, image in ipairs(PANEL_IMAGES) do
        result[#result + 1] = { index - 1, image.name }
    end
    if #result == 0 then result[1] = { 0, "<no images>" } end
    return result
end

local function get_texture_file_path(texture, alias, extension)
    if not (getFS and texture) then return nil end

    local ok, path = pcall(function()
        return getFS():update_path(alias, texture .. (extension or ".dds"))
    end)
    if ok and path then return path end
    return nil
end

local function font_family_content()
    load_runtime_font_catalog(false)

    local result = {}
    for index, family in ipairs(FONT_FAMILIES) do
        result[#result + 1] = { index - 1, family.name }
    end
    return result
end

local function font_variant_content(font_key)
    local family = get_current_font_family(font_key)
    local result = {}
    if family and family.variants then
        for index, variant in ipairs(family.variants) do
            result[#result + 1] = { index - 1, variant.name }
        end
    end
    if #result == 0 then result[1] = { 0, "<no variants>" } end
    return result
end

local function timer_font_variant_content() return font_variant_content("timer_font_family") end
local function key_send_now_font_variant_content() return font_variant_content("key_send_now_font_family") end
local custom_label_font_variant_content_functions = {}
for index = 1, CUSTOM_LABEL_COUNT do
    local label_index = index
    custom_label_font_variant_content_functions[index] = function()
        return font_variant_content("custom_label_" .. tostring(label_index) .. "_font_family")
    end
end

local function is_font_family_setting(key)
    return string.sub(tostring(key), -#"_font_family") == "_font_family"
end

local function is_font_variant_setting(key)
    return string.sub(tostring(key), -#"_font_variant") == "_font_variant"
end

local function is_image_index_setting(key)
    return key == "image_index" or key == "success_image_index"
end

local function get_font_family_key_for_variant_key(key)
    return string.sub(key, 1, #key - #"_font_variant") .. "_font_family"
end

local function get_mcm_value_type(default_value)
    if type(default_value) == "string" then return 0 end
    if type(default_value) == "boolean" then return 1 end
    return 2
end

local function read_mcm_setting_direct(key)
    local default_value = defaults[key]
    if axr_main and axr_main.config and axr_main.config.r_value then
        local read_ok, value = pcall(
            axr_main.config.r_value,
            axr_main.config,
            "mcm",
            mcm_path(key),
            get_mcm_value_type(default_value),
            default_value
        )
        if read_ok and value ~= nil then
            if is_custom_label_key(key) then return decode_custom_label_storage(value) end
            if is_tenth_step_setting(key) then return normalize_tenth_step(value) end
            return value
        end
    end

    local gathering = ui_mcm and ui_mcm.is_gathering and ui_mcm.is_gathering()
    if not gathering then return getv(key) end
    return default_value
end

local function write_mcm_setting_direct(key, value)
    local stored_value = is_custom_label_key(key) and encode_custom_label_storage(value) or value
    if axr_main and axr_main.config and axr_main.config.w_value then
        local write_ok = pcall(axr_main.config.w_value, axr_main.config, "mcm", mcm_path(key), stored_value)
        return write_ok
    end
    if ui_mcm and ui_mcm.set then
        local write_ok = pcall(ui_mcm.set, mcm_path(key), stored_value)
        return write_ok
    end
    return false
end

local function find_named_index(items, name)
    local wanted = string.lower(tostring(name or ""))
    if wanted == "" then return nil end
    for index, item in ipairs(items or {}) do
        if string.lower(tostring(item.name or "")) == wanted then return index - 1 end
    end
    return nil
end

local function deserialize_user_config_value(key, value)
    if is_image_index_setting(key) then
        if type(value) == "string" then
            local index = find_named_index(PANEL_IMAGES, value)
            if index ~= nil then return index end
        end
        return tonumber(value)
    end

    if is_font_family_setting(key) then
        if type(value) == "string" then
            local index = find_named_index(FONT_FAMILIES, value)
            if index ~= nil then return index end
        end
        return tonumber(value)
    end

    if is_font_variant_setting(key) then
        if type(value) == "string" then
            local family_key = get_font_family_key_for_variant_key(key)
            local family = get_font_family_by_index(read_mcm_setting_direct(family_key))
            local index = family and find_named_index(family.variants, value) or nil
            if index ~= nil then return index end
        end
        return tonumber(value)
    end

    local default_value = defaults[key]
    if type(default_value) == "number" then
        if is_tenth_step_setting(key) then return normalize_tenth_step(value) end
        return tonumber(value)
    end
    if type(default_value) == "boolean" then
        if value == true or value == 1 or value == "1" or value == "true" then return true end
        if value == false or value == 0 or value == "0" or value == "false" then return false end
        return nil
    end
    if type(default_value) == "string" then return tostring(value or "") end
    return nil
end

local function serialize_user_config_value(key)
    local value = read_mcm_setting_direct(key)
    if is_image_index_setting(key) then
        local index = clamp_index(value, defaults[key])
        local image = index and PANEL_IMAGES[index + 1] or nil
        return image and image.name or tonumber(value) or defaults[key]
    end
    if is_font_family_setting(key) then
        local family = get_font_family_by_index(value)
        return family and family.name or tonumber(value) or defaults[key]
    end
    if is_font_variant_setting(key) then
        local family_key = get_font_family_key_for_variant_key(key)
        local family = get_font_family_by_index(read_mcm_setting_direct(family_key))
        local index = math.floor((tonumber(value) or 0) + 0.5) + 1
        local variant = family and family.variants and family.variants[index] or nil
        return variant and variant.name or tonumber(value) or defaults[key]
    end
    return value
end

local function save_user_config()
    local config = transition_countdown_user_config
    if not (config and config.write) then return false end

    local values = {}
    for key, _ in pairs(defaults) do
        values[key] = serialize_user_config_value(key)
    end
    local write_ok, saved = pcall(config.write, values)
    if write_ok and saved == true then
        user_config_dirty = false
        return true
    end
    return false
end

local function apply_user_config(values)
    if type(values) ~= "table" then return false end
    local family_keys = {}
    local regular_keys = {}
    local variant_keys = {}
    for key, _ in pairs(values) do
        if defaults[key] ~= nil then
            if is_font_family_setting(key) then
                family_keys[#family_keys + 1] = key
            elseif is_font_variant_setting(key) then
                variant_keys[#variant_keys + 1] = key
            else
                regular_keys[#regular_keys + 1] = key
            end
        end
    end
    table.sort(family_keys)
    table.sort(regular_keys)
    table.sort(variant_keys)

    local changed = false
    for _, keys in ipairs({ family_keys, regular_keys, variant_keys }) do
        for _, key in ipairs(keys) do
            local value = deserialize_user_config_value(key, values[key])
            local current_value = deserialize_user_config_value(key, read_mcm_setting_direct(key))
            if value ~= nil and current_value ~= value and write_mcm_setting_direct(key, value) then
                changed = true
            end
        end
    end
    if changed and axr_main and axr_main.config and axr_main.config.save then
        pcall(axr_main.config.save, axr_main.config)
    end
    return changed
end

local function load_user_config_once()
    if user_config_loaded then return end
    local config = transition_countdown_user_config
    if not (config and config.read) then return end

    local read_ok, values, metadata = pcall(config.read)
    if not read_ok or type(values) ~= "table" then return end
    user_config_loaded = true
    apply_user_config(values)
    if type(metadata) ~= "table" or tonumber(metadata.format_version) ~= tonumber(config.FORMAT_VERSION) then
        save_user_config()
    end
end

local function mark_user_config_dirty()
    user_config_dirty = true
    user_config_changed_at = time_continual and time_continual() or (time_global and time_global() or 0)
    if user_config_save_pending or not CreateTimeEvent then return end

    user_config_save_pending = true
    CreateTimeEvent("transition_countdown_user_config", "save", 0.25, function()
        local now = time_continual and time_continual() or (time_global and time_global() or user_config_changed_at)
        if now - user_config_changed_at < 500 then return false end
        user_config_save_pending = false
        if user_config_dirty then save_user_config() end
        return true
    end)
end

local function flush_user_config()
    if user_config_dirty then save_user_config() end
end

local function on_mcm_settings_changed(changes)
    if type(changes) ~= "table" then return end
    for path, _ in pairs(changes) do
        local path_text = tostring(path)
        if path_text == MOD_ID or string.sub(path_text, 1, #MOD_ID + 1) == MOD_ID .. "/" then
            user_config_dirty = true
            save_user_config()
            return
        end
    end
end

local function register_user_config_callback()
    if user_config_callback_registered or not RegisterScriptCallback then return end
    local register_ok = pcall(RegisterScriptCallback, "mcm_option_change", on_mcm_settings_changed)
    user_config_callback_registered = register_ok
end

local function fade_duration_ms()
    return math.floor(clamp(get_num("fade_time"), 0, 2) * 1000 + 0.5)
end

local function text_size_scale_from_level(level)
    local percent = math.floor((tonumber(level) or 100) + 0.5)
    percent = math.max(TEXT_SIZE_MIN_PERCENT, math.min(TEXT_SIZE_MAX_PERCENT, percent))
    return percent / 100
end

local function text_size_level(value, font_key)
    value = tonumber(value)
    if not value then return 100 end

    value = math.floor(value + 0.5)
    local max_level = math.min(TEXT_SIZE_MAX_PERCENT, get_font_size_count(font_key))
    if value < TEXT_SIZE_MIN_PERCENT then return TEXT_SIZE_MIN_PERCENT end
    if value > max_level then return max_level end
    return value
end

local function get_text_size_level(key)
    return text_size_level(get_num(key), get_font_family_key_for_size_key(key))
end

local function round_pixel(value)
    return math.floor((tonumber(value) or 0) + 0.5)
end

local function get_ui_aspect_correction(current_device)
    current_device = current_device or (device and device())
    if not (current_device and current_device.width and current_device.height) then return 1 end

    local correction = (current_device.width / current_device.height) / (UI_W / UI_H)
    return correction > 0 and correction or 1
end

local function get_atlas_font_entry(size, font_key)
    local family = get_current_font_family(font_key)
    if not family or family.mode ~= "atlas" then return nil end
    return family.sizes and family.sizes[text_size_level(size, font_key)] or nil
end

local function parse_font_coord(value)
    if not value then return nil end

    local x1, y1, x2, y2 = string.match(value, "^%s*([%-%.%d]+)%s*,%s*([%-%.%d]+)%s*,%s*([%-%.%d]+)%s*,%s*([%-%.%d]+)")
    if not x1 then return nil end
    return tonumber(x1) or 0, tonumber(y1) or 0, tonumber(x2) or 0, tonumber(y2) or 0
end

local function load_font_atlas(entry)
    if not (entry and entry.texture) then return nil end
    if font_atlas_cache[entry.texture] ~= nil then return font_atlas_cache[entry.texture] or nil end

    local atlas = { texture = entry.texture, height = 0, coords = {} }
    if entry.coords and entry.height then
        atlas.height = tonumber(entry.height) or 0
        for code, coord in pairs(entry.coords) do
            if coord and coord[1] and coord[3] and coord[3] > coord[1] and coord[4] > coord[2] then
                atlas.coords[code] = { x1 = coord[1], y1 = coord[2], x2 = coord[3], y2 = coord[4], width = coord[3] - coord[1], height = coord[4] - coord[2] }
            end
        end
        if atlas.height > 0 then
            font_atlas_cache[entry.texture] = atlas
            return atlas
        end
    end

    local ini_path = get_texture_file_path(entry.texture, "$game_textures$", ".ini")
    if not ini_path then
        ini_path = get_texture_file_path(entry.texture, "$textures$", ".ini")
    end

    local ok = pcall(function()
        local ini = ini_file(ini_path or ("textures\\" .. entry.texture .. ".ini"))
        atlas.height = tonumber(ini:r_string_ex("symbol_coords", "height")) or 0
        for code = 0, 255 do
            local x1, y1, x2, y2 = parse_font_coord(ini:r_string_ex("symbol_coords", string.format("%03d", code)))
            if x1 and x2 > x1 and y2 > y1 then
                atlas.coords[code] = { x1 = x1, y1 = y1, x2 = x2, y2 = y2, width = x2 - x1, height = y2 - y1 }
            end
        end
    end)

    if not ok or atlas.height <= 0 then
        font_atlas_cache[entry.texture] = false
        return nil
    end

    font_atlas_cache[entry.texture] = atlas
    return atlas
end

local function text_size_scale(level, font_key)
    local normalized_level = text_size_level(level, font_key)
    local family = get_current_font_family(font_key)
    local entry = family and family.sizes and family.sizes[normalized_level]
    return entry and tonumber(entry.scale) or text_size_scale_from_level(normalized_level)
end

local function normalize_text_size_setting(key)
    if not (ui_mcm and ui_mcm.set) then return end

    local current = getv(key)
    local normalized = text_size_level(current, get_font_family_key_for_size_key(key))
    if tonumber(current) ~= normalized then
        ui_mcm.set(mcm_path(key), normalized)
    end
end

function normalize_text_size_settings()
    normalize_text_size_setting("timer_size")
    normalize_text_size_setting("key_send_now_size")
    for index = 1, CUSTOM_LABEL_COUNT do
        normalize_text_size_setting("custom_label_" .. tostring(index) .. "_size")
    end
end

local function normalize_font_variant_setting(font_key)
    if not (ui_mcm and ui_mcm.set) then return end
    local variant_key = get_font_variant_key_for_font_key(font_key)
    local current = getv(variant_key)
    local normalized = clamp_font_variant_index(current, font_key)
    if tonumber(current) ~= normalized then
        ui_mcm.set(mcm_path(variant_key), normalized)
    end
end

function normalize_font_variant_settings()
    normalize_font_variant_setting("timer_font_family")
    normalize_font_variant_setting("key_send_now_font_family")
    for index = 1, CUSTOM_LABEL_COUNT do
        normalize_font_variant_setting("custom_label_" .. tostring(index) .. "_font_family")
    end
end

local function reset_font_variant(font_key)
    if ui_mcm and ui_mcm.set then
        ui_mcm.set(mcm_path(get_font_variant_key_for_font_key(font_key)), 0)
    end
    normalize_font_variant_setting(font_key)
    normalize_text_size_settings()
end

local function on_timer_font_family_changed() reset_font_variant("timer_font_family") end
local function on_key_send_now_font_family_changed() reset_font_variant("key_send_now_font_family") end
local custom_label_font_family_changed_functions = {}
for index = 1, CUSTOM_LABEL_COUNT do
    local label_index = index
    custom_label_font_family_changed_functions[index] = function()
        reset_font_variant("custom_label_" .. tostring(label_index) .. "_font_family")
    end
end

local function font_countdown(size, font_key)
    local family = get_current_font_family(font_key)
    if family and family.mode == "atlas" then return nil end
    local entry = family and family.sizes and family.sizes[text_size_level(size, font_key)]
    local getters = entry and entry.getters or nil
    if getters then
        for index = 1, #getters do
            local getter = _G[getters[index]]
            if getter then
                local ok, font = pcall(getter)
                if ok and font then return font end
            end
        end
    end

    if GetFontLetterica18Russian then return GetFontLetterica18Russian() end
    if GetFontLetterica16Russian then return GetFontLetterica16Russian() end
    if GetFontSmall then return GetFontSmall() end
    return nil, 0
end

local function get_key_name(key)
    key = tonumber(key)
    if not key or key <= 0 then return "" end

    if ui_mcm and ui_mcm.display_key then
        local ok, name = pcall(ui_mcm.display_key, key)
        if ok and name ~= nil then return trim_text(name) end
    end

    return ""
end

local KEY_BIND_BLOCKED_KEYS = {
    [58] = true,
    [337] = true,
    [338] = true,
    [339] = true,
}

local function is_empty_key_name(name)
    name = trim_text(name)
    if name == "" or string.sub(name, 1, 1) == "<" then return true end
    if string.find(name, "не назнач", 1, true) or string.find(name, "Не назнач", 1, true) then return true end

    local lower = string.lower(name)
    return lower == "none" or lower == "unassigned" or string.find(lower, "not bound", 1, true) or string.find(lower, "not assigned", 1, true)
end

local function get_key_send_now_text()
    local key_name = get_key_name(get_num("key_send_now"))
    if is_empty_key_name(key_name) then return "" end
    return key_name
end

local function hide_transition_ui(wnd)
    if not wnd then return end

    if wnd.message_box then
        pcall(function() wnd.message_box:ShowDialog(false) end)
        pcall(function() wnd.message_box:HideDialog() end)
    end

    pcall(function() wnd:Show(false) end)
    pcall(function() wnd:HideDialog() end)
end

local function safe_obj_id(obj)
    if not obj or not obj.id then return nil end
    local ok, id = pcall(function() return obj:id() end)
    if ok then return id end
    return nil
end

local function safe_obj_name(obj)
    if not obj or not obj.name then return nil end
    local ok, name = pcall(function() return obj:name() end)
    if ok then return name end
    return nil
end

local function get_restrictor_by_id(id)
    if not id then return nil end

    if level and level.object_by_id then
        local ok, obj = pcall(level.object_by_id, id)
        if ok and obj then return obj end
    end

    if alife_object then
        local ok, obj = pcall(alife_object, id)
        if ok and obj and obj.inside then return obj end
    end

    return nil
end

local function get_restrictor(session)
    if not session then return nil end

    local obj = get_restrictor_by_id(session.restrictor_id)
    if obj then return obj end

    local name = session.restrictor_name
    if name and db and db.zone_by_name then
        local z = db.zone_by_name[name]
        if z then return z end
    end

    return nil
end

local function actor_inside_restrictor(session)
    if not (db and db.actor and db.actor.position) then
        return false
    end

    local restr = get_restrictor(session)
    if restr and restr.inside then
        local ok, inside = pcall(function()
            return restr:inside(db.actor:position())
        end)
        if ok then
            return inside == true
        end
        return false
    end

    return false
end

local function format_remaining(ms)
    if ms < 0 then ms = 0 end
    local sec = ms / 1000
    if get_bool("decimals") then
        return string.format("%.1f", sec)
    end
    return tostring(math.ceil(sec))
end

class "STACCountdownOverlay" (CUIScriptWnd)

function STACCountdownOverlay:__init() super()
    self:SetWndRect(Frect():set(0, 0, UI_W, UI_H))
    self:SetAutoDelete(true)
    self.failed = false
    self._fade_factor = 1
    self._fade_mode = nil
    self._last_layout_text = nil

    local ok = pcall(function()
        self.bg = CUIStatic()
        self:AttachChild(self.bg)
        self.bg:SetAutoDelete(true)
        self.bg:Show(false)
        self._panel_texture = nil
        self:SetPanelImage(get_image_entry_by_key("image_index", defaults.image_index), "image")

        self.timer = CUITextWnd()
        self:AttachChild(self.timer)
        self.timer:SetAutoDelete(true)
        local timer_size = get_text_size_level("timer_size")
        local timer_font_family = clamp_font_family_index(get_num("timer_font_family"))
        local f = font_countdown(timer_size, "timer_font_family")
        if f then self.timer:SetFont(f) end
        self._timer_size_level = timer_size
        self._timer_font_family = timer_font_family
        if CGameFont then
            pcall(function() self.timer:SetTextAlignment(CGameFont.alCenter) end)
            pcall(function() self.timer:SetVTextAlignment(CGameFont.avCenter) end)
        end
        self.timer:SetTextColor(GetARGB(255, 255, 255, 255))
        self.timer:SetText("")

        self.key_send_now = CUITextWnd()
        self:AttachChild(self.key_send_now)
        self.key_send_now:SetAutoDelete(true)
        local key_send_now_size = get_text_size_level("key_send_now_size")
        local key_send_now_font_family = clamp_font_family_index(get_num("key_send_now_font_family"))
        local key_send_now_font = font_countdown(key_send_now_size, "key_send_now_font_family")
        if key_send_now_font then self.key_send_now:SetFont(key_send_now_font) end
        self._key_send_now_size_level = key_send_now_size
        self._key_send_now_font_family = key_send_now_font_family
        if CGameFont then
            pcall(function() self.key_send_now:SetTextAlignment(CGameFont.alCenter) end)
            pcall(function() self.key_send_now:SetVTextAlignment(CGameFont.avCenter) end)
        end
        self.key_send_now:SetTextColor(GetARGB(255, 255, 255, 255))
        self.key_send_now:SetText("")

        self.custom_label = {}
        self._custom_label_size_level = {}
        self._custom_label_font_family = {}
    end)

    if not ok then
        self.failed = true
        return
    end

    local hud = get_hud and get_hud()
    if hud then
        hud:AddDialogToRender(self)
        self._hud = true
        self:StartFadeIn()
    else
        self.failed = true
    end
end

function STACCountdownOverlay:SetPanelImage(entry, color_profile)
    if self.failed or type(entry) ~= "table" then return end

    color_profile = color_profile == "success_image" and "success_image" or "image"
    if self._panel_entry == entry and self._panel_color_profile == color_profile then return end

    self._panel_entry = entry
    self._panel_color_profile = color_profile
    self._texture_width = tonumber(entry.width)
    self._texture_height = tonumber(entry.height)
    self._panel_force_texture_switch = true
    self.bg:Show(false)
    self:FinishFade()
end

function STACCountdownOverlay:UpdateRuntimePanelImage(target_width, target_height)
    local entry = self._panel_entry
    if type(entry) ~= "table" then return false end

    local runtime = get_ttf_runtime()
    if not (runtime and runtime.render_image) then return false end

    local avoid_texture_name = self._panel_force_texture_switch and self._panel_texture or nil
    local ok, render_ok, texture_name, texture_width, texture_height = pcall(
        runtime.render_image,
        entry,
        target_width,
        target_height,
        avoid_texture_name
    )
    if not ok or render_ok ~= true or not texture_name then return false end

    if self._panel_texture ~= texture_name or self._panel_force_texture_switch then
        self.bg:InitTexture(texture_name)
        self.bg:SetStretchTexture(true)
        self._panel_texture = texture_name
    end
    self._panel_force_texture_switch = false
    self._texture_width = texture_width
    self._texture_height = texture_height
    self.bg:Show(true)
    return true
end

function STACCountdownOverlay:StartFadeIn()
    local duration = fade_duration_ms()
    if duration <= 0 then
        self._fade_factor = 1
        self._fade_mode = nil
        return
    end

    self._fade_factor = 0
    self._fade_mode = 1
    self._fade_start = time_global and time_global() or 0
    self._fade_start_factor = 0
end

function STACCountdownOverlay:FinishFade()
    self._fade_factor = 1
    self._fade_mode = nil
end

function STACCountdownOverlay:DestroyNow()
    if self._destroyed then return end
    self._destroyed = true

    if self._hud then
        local hud = get_hud and get_hud()
        if hud then pcall(function() hud:RemoveDialogToRender(self) end) end
        self._hud = false
    end
end

function STACCountdownOverlay:Destroy()
    if self._destroyed then return end

    local duration = fade_duration_ms()
    if duration <= 0 or not self._hud then
        self:DestroyNow()
        return
    end

    self._fade_mode = -1
    self._fade_start = time_global and time_global() or 0
    self._fade_start_factor = self:GetFadeFactor()
end

function STACCountdownOverlay:IsReady()
    return self.failed ~= true
end

local function hide_texture_window(window)
    window:SetWndSize(vector2():set(0, 0))
    window:SetTextureColor(GetARGB(0, 255, 255, 255))
    pcall(function() window:Show(false) end)
end

local function create_texture_window(parent, hidden)
    local window = CUIStatic()
    parent:AttachChild(window)
    window:SetAutoDelete(true)
    window:SetStretchTexture(true)
    if hidden then hide_texture_window(window) end
    return window
end

function STACCountdownOverlay:GetAtlasGlyph(group_key, index)
    self.atlas_text = self.atlas_text or {}
    self.atlas_text[group_key] = self.atlas_text[group_key] or {}

    local glyph = self.atlas_text[group_key][index]
    if glyph then return glyph end

    glyph = create_texture_window(self, false)
    self.atlas_text[group_key][index] = glyph
    return glyph
end

function STACCountdownOverlay:GetDynamicTextSlot(slot_key)
    self.dynamic_text_slots = self.dynamic_text_slots or {}

    local slot = self.dynamic_text_slots[slot_key]
    if slot then return slot end

    slot = create_texture_window(self, true)
    self.dynamic_text_slots[slot_key] = slot
    return slot
end

function STACCountdownOverlay:HideDynamicTextSlot(slot_key)
    if not (self.dynamic_text_slots and self.dynamic_text_slots[slot_key]) then return end

    hide_texture_window(self.dynamic_text_slots[slot_key])
end

function STACCountdownOverlay:GetDynamicGlyph(group_key, index)
    self.dynamic_glyphs = self.dynamic_glyphs or {}
    self.dynamic_glyphs[group_key] = self.dynamic_glyphs[group_key] or {}

    local glyph = self.dynamic_glyphs[group_key][index]
    if glyph then return glyph end

    glyph = create_texture_window(self, true)
    self.dynamic_glyphs[group_key][index] = glyph
    return glyph
end

local function hide_glyph_pool(pool, first_index)
    if not pool then return end
    for index = first_index or 1, #pool do
        local glyph = pool[index]
        if glyph then
            hide_texture_window(glyph)
        end
    end
end

function STACCountdownOverlay:HideDynamicGlyphs(group_key)
    if not (self.dynamic_glyphs and self.dynamic_glyphs[group_key]) then return end
    hide_glyph_pool(self.dynamic_glyphs[group_key])
end

local function dynamic_argb(color, fade)
    local alpha = clamp(color and color.a or 255, 0, 255)
    alpha = math.floor(alpha * clamp(fade or 1, 0, 1) + 0.5)
    return GetARGB(
        alpha,
        clamp(color and color.r or 255, 0, 255),
        clamp(color and color.g or 255, 0, 255),
        clamp(color and color.b or 255, 0, 255)
    )
end

function STACCountdownOverlay:RenderDynamicTimer(text_window, text, family, variant_index, size_percent, rect_x, rect_y, rect_w, rect_h, color, fade)
    local runtime = get_ttf_runtime()
    if not (runtime and runtime.render_slot and family and can_render_dynamic_text(family, variant_index) and text and text ~= "") then
        self:HideDynamicGlyphs("timer")
        return false
    end

    local render_result = { pcall(runtime.render_slot, "timer", {
        mode = "timer_atlas",
        family = family,
        variant_index = variant_index,
        size_percent = size_percent,
    }) }
    local ok = render_result[1]
    local render_ok = render_result[2]
    local texture_name = render_result[3]
    local generation = render_result[6]
    local meta = render_result[7]

    if not ok or render_ok ~= true or not texture_name or not meta or not meta.coords then
        return false
    end

    local text_string = tostring(text or "")
    local char_count = string.len(text_string)
    if char_count <= 0 then
        self:HideDynamicGlyphs("timer")
        return true
    end

    local cell_height = tonumber(meta.cell_height) or 1
    local glyph_gap = tonumber(meta.gap) or 0
    local total_width = 0
    for index = 1, char_count do
        local coord = meta.coords[string.byte(text_string, index)]
        total_width = total_width + (coord and coord.width or 1)
        if index < char_count then total_width = total_width + glyph_gap end
    end
    local scale = math.min(rect_w / math.max(1, total_width), rect_h / math.max(1, cell_height))
    if scale <= 0 then scale = 1 end

    local draw_width = total_width * scale
    local draw_height = cell_height * scale
    local cursor_x = rect_x + (rect_w - draw_width) / 2
    local draw_y = rect_y + (rect_h - draw_height) / 2
    local tint = dynamic_argb(color, fade)
    local visible = 0

    for index = 1, char_count do
        local code = string.byte(text_string, index)
        local coord = meta.coords[code]
        if coord then
            visible = visible + 1
            local glyph = self:GetDynamicGlyph("timer", visible)
            if glyph._loaded_generation ~= generation then
                glyph:InitTexture(texture_name)
                glyph:SetStretchTexture(true)
                glyph._loaded_generation = generation
                glyph._texture_name = texture_name
            end
            glyph:SetTextureRect(Frect():set(coord.x1, coord.y1, coord.x2, coord.y2))
            glyph:SetWndPos(vector2():set(round_pixel(cursor_x), round_pixel(draw_y)))
            glyph:SetWndSize(vector2():set(math.max(1, round_pixel(coord.width * scale)), math.max(1, round_pixel(cell_height * scale))))
            glyph:SetTextureColor(tint)
            pcall(function() glyph:Show(true) end)
        end
        cursor_x = cursor_x + ((coord and coord.width or 1) + (index < char_count and glyph_gap or 0)) * scale
    end

    hide_glyph_pool(self.dynamic_glyphs and self.dynamic_glyphs.timer, visible + 1)

    if text_window then
        text_window:SetText("")
        pcall(function() text_window:Show(false) end)
    end
    self:HideDynamicTextSlot("timer")
    return true
end

function STACCountdownOverlay:RenderDynamicTextSlot(slot_key, text_window, text, family, variant_index, size_percent, rect_x, rect_y, rect_w, rect_h, color, fade)
    local runtime = get_ttf_runtime()
    if not (runtime and runtime.render_slot and family and can_render_dynamic_text(family, variant_index) and text and text ~= "") then
        self:HideDynamicTextSlot(slot_key)
        return false
    end

    local ok, render_ok, texture_name, texture_rect_w, texture_rect_h, generation = pcall(runtime.render_slot, slot_key, {
        mode = "text",
        text = tostring(text or ""),
        family = family,
        variant_index = variant_index,
        size_percent = size_percent,
    })

    if not ok or render_ok ~= true or not texture_name then
        return false
    end

    local slot = self:GetDynamicTextSlot(slot_key)
    if slot._loaded_generation ~= generation then
        slot:InitTexture(texture_name)
        slot:SetStretchTexture(true)
        slot._texture_name = texture_name
        slot._loaded_generation = generation
    end

    if texture_rect_w and texture_rect_h then
        slot:SetTextureRect(Frect():set(0, 0, texture_rect_w, texture_rect_h))
    end
    slot:SetWndPos(vector2():set(rect_x, rect_y))
    slot:SetWndSize(vector2():set(rect_w, rect_h))
    slot:SetTextureColor(dynamic_argb(color, fade))
    pcall(function() slot:Show(true) end)

    if text_window then
        text_window:SetText("")
        pcall(function() text_window:Show(false) end)
    end

    return true
end

function STACCountdownOverlay:ShowFallbackTextWnd(text_window)
    if not text_window then return end
    pcall(function() text_window:Show(true) end)
end

function STACCountdownOverlay:HideAtlasText(group_key)
    if not (self.atlas_text and self.atlas_text[group_key]) then return end
    hide_glyph_pool(self.atlas_text[group_key])
end

function STACCountdownOverlay:RenderAtlasText(group_key, text, font_key, size_level, rect_x, rect_y, rect_w, rect_h, color)
    local entry = get_atlas_font_entry(size_level, font_key)
    if not entry then return false end

    text = tostring(text or "")
    if text == "" then
        self:HideAtlasText(group_key)
        return true
    end

    local atlas = load_font_atlas(entry)
    if not atlas then
        self:HideAtlasText(group_key)
        return false
    end

    local advances = {}
    local total_width = 0
    for index = 1, string.len(text) do
        local code = string.byte(text, index)
        local coord = atlas.coords[code] or atlas.coords[63]
        local width = coord and coord.width or math.floor(atlas.height * 0.5 + 0.5)
        advances[index] = { code = code, coord = coord, width = width }
        total_width = total_width + width
    end

    if total_width <= 0 then
        self:HideAtlasText(group_key)
        return true
    end

    local scale = math.min(rect_w / total_width, rect_h / atlas.height, 1)
    if scale <= 0 then scale = 1 end
    if scale > 0.98 then scale = 1 end

    local cursor_x = round_pixel(rect_x + (rect_w - total_width * scale) / 2)
    local base_y = round_pixel(rect_y + (rect_h - atlas.height * scale) / 2)
    local visible_index = 0

    for index = 1, #advances do
        local item = advances[index]
        local coord = item.coord
        if coord and item.code ~= 32 then
            visible_index = visible_index + 1
            local glyph = self:GetAtlasGlyph(group_key, visible_index)
            glyph:InitTexture(atlas.texture)
            glyph:SetTextureRect(Frect():set(coord.x1, coord.y1, coord.x2, coord.y2))
            glyph:SetWndPos(vector2():set(round_pixel(cursor_x), base_y))
            glyph:SetWndSize(vector2():set(math.max(1, round_pixel(coord.width * scale)), math.max(1, round_pixel(coord.height * scale))))
            glyph:SetTextureColor(color)
            pcall(function() glyph:Show(true) end)
        end
        cursor_x = cursor_x + round_pixel(item.width * scale)
    end

    hide_glyph_pool(self.atlas_text and self.atlas_text[group_key], visible_index + 1)

    return true
end

function STACCountdownOverlay:GetKeySendNowText()
    local key_send_now = math.floor(get_num("key_send_now") + 0.5)
    if self._key_send_now_key ~= key_send_now then
        self._key_send_now_key = key_send_now
        self._key_send_now_text = get_key_send_now_text()
    end
    return self._key_send_now_text
end

function STACCountdownOverlay:GetCustomLabelWindow(index)
    if self.custom_label[index] then return self.custom_label[index] end

    local custom_label = CUITextWnd()
    self:AttachChild(custom_label)
    custom_label:SetAutoDelete(true)

    local suffix = tostring(index)
    local custom_font_key = "custom_label_" .. suffix .. "_font_family"
    local custom_size_key = "custom_label_" .. suffix .. "_size"
    local custom_font = font_countdown(get_text_size_level(custom_size_key), custom_font_key)
    if custom_font then custom_label:SetFont(custom_font) end

    if CGameFont then
        pcall(function() custom_label:SetTextAlignment(CGameFont.alCenter) end)
        pcall(function() custom_label:SetVTextAlignment(CGameFont.avCenter) end)
    end

    custom_label:SetTextColor(GetARGB(255, 255, 255, 255))
    custom_label:SetText("")
    self.custom_label[index] = custom_label
    self._custom_label_size_level[index] = get_text_size_level(custom_size_key)
    self._custom_label_font_family[index] = clamp_font_family_index(get_num(custom_font_key))
    return custom_label
end

function STACCountdownOverlay:GetFadeFactor()
    if not self._fade_mode then return self._fade_factor or 1 end

    local duration = fade_duration_ms()
    if duration <= 0 then
        return self._fade_mode > 0 and 1 or 0
    end

    local now = time_global and time_global() or self._fade_start
    local progress = clamp((now - (self._fade_start or now)) / duration, 0, 1)
    if self._fade_mode > 0 then
        return progress
    end
    return (self._fade_start_factor or 1) * (1 - progress)
end

function STACCountdownOverlay:UpdateFade()
    self._fade_factor = self:GetFadeFactor()

    if self._fade_mode == 1 and self._fade_factor >= 1 then
        self._fade_mode = nil
    elseif self._fade_mode == -1 and self._fade_factor <= 0 then
        self:DestroyNow()
        return false
    end

    return true
end

function STACCountdownOverlay:ApplyLayout(text)
    if self.failed then return end
    self._last_layout_text = text

    local image_profile = self._panel_color_profile == "success_image" and "success_image" or "image"
    local image_scale_key = image_profile == "success_image" and "success_image_scale" or "image_scale"
    local image_scale = clamp(get_num(image_scale_key), IMAGE_SCALE_MIN, IMAGE_SCALE_MAX)
    local timer_size = get_text_size_level("timer_size")
    local key_send_now_size = get_text_size_level("key_send_now_size")
    local timer_font_family = clamp_font_family_index(get_num("timer_font_family"))
    local key_send_now_font_family = clamp_font_family_index(get_num("key_send_now_font_family"))
    local timer_font_variant = get_current_font_variant_index("timer_font_family")
    local key_send_now_font_variant = get_current_font_variant_index("key_send_now_font_family")
    local alpha_key = image_profile == "success_image" and "success_image_alpha" or "image_alpha"
    local image_r_key = image_profile == "success_image" and "success_image_r" or "image_r"
    local image_g_key = image_profile == "success_image" and "success_image_g" or "image_g"
    local image_b_key = image_profile == "success_image" and "success_image_b" or "image_b"
    local alpha = clamp(get_num(alpha_key), 0, 100)
    local timer_alpha = clamp(get_num("timer_alpha"), 0, 100)
    local key_send_now_alpha = clamp(get_num("key_send_now_alpha"), 0, 100)

    local current_device = device and device()
    local corr = get_ui_aspect_correction(current_device)

    local cx = UI_W / 2 + get_num("group_x")
    local cy = UI_H / 2 + get_num("group_y")
    local texture_width = tonumber(self._texture_width)
    local texture_height = tonumber(self._texture_height)
    if self._panel_entry and not (texture_width and texture_height and texture_width > 0 and texture_height > 0) then
        self:UpdateRuntimePanelImage(0, 0)
        texture_width = tonumber(self._texture_width)
        texture_height = tonumber(self._texture_height)
    end
    local h = 0
    local w = 0
    if texture_width and texture_height and texture_width > 0 and texture_height > 0 then
        h = BASE_PANEL_H * image_scale
        w = h * (texture_width / texture_height) / corr
    end
    local image_x_key = image_profile == "success_image" and "success_image_x" or "image_x"
    local image_y_key = image_profile == "success_image" and "success_image_y" or "image_y"
    local left = cx + get_num(image_x_key) - w / 2
    local top = cy + get_num(image_y_key) - h / 2

    self.bg:SetWndPos(vector2():set(left, top))
    self.bg:SetWndSize(vector2():set(w, h))
    if w > 0 and h > 0 and self._panel_entry then
        local pixel_width = w
        local pixel_height = h
        if current_device and current_device.width and current_device.height then
            pixel_width = w * current_device.width / UI_W
            pixel_height = h * current_device.height / UI_H
        end
        self:UpdateRuntimePanelImage(math.ceil(pixel_width), math.ceil(pixel_height))
    end
    local fade = clamp(self:GetFadeFactor(), 0, 1)
    local image_r = clamp(get_num(image_r_key), 0, 255)
    local image_g = clamp(get_num(image_g_key), 0, 255)
    local image_b = clamp(get_num(image_b_key), 0, 255)
    self.bg:SetTextureColor(GetARGB(math.floor(alpha * fade * 255 / 100 + 0.5), image_r, image_g, image_b))

    if self._timer_size_level ~= timer_size or self._timer_font_family ~= timer_font_family then
        local timer_font = font_countdown(timer_size, "timer_font_family")
        if timer_font then self.timer:SetFont(timer_font) end
        self._timer_size_level = timer_size
        self._timer_font_family = timer_font_family
    end

    local timer_scale = text_size_scale(timer_size, "timer_font_family")
    local tw = math.max(1, TIMER_BASE_WIDTH * timer_scale)
    local th = math.max(1, TIMER_BASE_HEIGHT * timer_scale)
    local tx = cx + get_num("timer_x") - tw / 2
    local ty = cy + get_num("timer_y") - th / 2

    self.timer:SetWndPos(vector2():set(tx, ty))
    self.timer:SetWndSize(vector2():set(tw, th))
    local timer_r = clamp(get_num("timer_r"), 0, 255)
    local timer_g = clamp(get_num("timer_g"), 0, 255)
    local timer_b = clamp(get_num("timer_b"), 0, 255)
    local timer_a = math.floor(timer_alpha * 255 / 100 + 0.5)
    local timer_color = GetARGB(math.floor(timer_alpha * fade * 255 / 100 + 0.5), timer_r, timer_g, timer_b)
    self.timer:SetTextColor(timer_color)
    local timer_family = get_current_font_family("timer_font_family")
    local timer_dynamic = can_render_dynamic_text(timer_family, timer_font_variant)
    if self:RenderDynamicTimer(self.timer, text or "", timer_family, timer_font_variant, timer_size, tx, ty, tw, th, { r = timer_r, g = timer_g, b = timer_b, a = timer_a }, fade) then
        self:HideAtlasText("timer")
    elseif timer_dynamic then
        self:HideDynamicGlyphs("timer")
        self:HideAtlasText("timer")
        self:ShowFallbackTextWnd(self.timer)
        self.timer:SetText(text or "")
    elseif get_atlas_font_entry(timer_size, "timer_font_family") then
        self:ShowFallbackTextWnd(self.timer)
        self.timer:SetText("")
        if not self:RenderAtlasText("timer", text or "", "timer_font_family", timer_size, tx, ty, tw, th, timer_color) then
            self.timer:SetText(text or "")
        end
    else
        self:HideDynamicTextSlot("timer")
        self:HideDynamicGlyphs("timer")
        self:HideAtlasText("timer")
        self:ShowFallbackTextWnd(self.timer)
        self.timer:SetText(text or "")
    end

    if self._key_send_now_size_level ~= key_send_now_size or self._key_send_now_font_family ~= key_send_now_font_family then
        local key_send_now_font = font_countdown(key_send_now_size, "key_send_now_font_family")
        if key_send_now_font then self.key_send_now:SetFont(key_send_now_font) end
        self._key_send_now_size_level = key_send_now_size
        self._key_send_now_font_family = key_send_now_font_family
    end

    local key_send_now_scale = text_size_scale(key_send_now_size, "key_send_now_font_family")
    local key_send_now_w = math.max(1, KEY_SEND_NOW_BASE_WIDTH * key_send_now_scale)
    local key_send_now_h = math.max(1, KEY_SEND_NOW_BASE_HEIGHT * key_send_now_scale)
    local key_send_now_x = cx + get_num("key_send_now_x") - key_send_now_w / 2
    local key_send_now_y = cy + get_num("key_send_now_y") - key_send_now_h / 2

    self.key_send_now:SetWndPos(vector2():set(key_send_now_x, key_send_now_y))
    self.key_send_now:SetWndSize(vector2():set(key_send_now_w, key_send_now_h))
    local key_send_now_r = clamp(get_num("key_send_now_r"), 0, 255)
    local key_send_now_g = clamp(get_num("key_send_now_g"), 0, 255)
    local key_send_now_b = clamp(get_num("key_send_now_b"), 0, 255)
    local key_send_now_a = math.floor(key_send_now_alpha * 255 / 100 + 0.5)
    local key_send_now_color = GetARGB(math.floor(key_send_now_alpha * fade * 255 / 100 + 0.5), key_send_now_r, key_send_now_g, key_send_now_b)
    local key_send_now_text = (text and text ~= "") and self:GetKeySendNowText() or ""
    self.key_send_now:SetTextColor(key_send_now_color)
    local key_send_now_family_data = get_current_font_family("key_send_now_font_family")
    local key_send_now_dynamic = can_render_dynamic_text(key_send_now_family_data, key_send_now_font_variant)
    if self:RenderDynamicTextSlot("key_send_now", self.key_send_now, key_send_now_text, key_send_now_family_data, key_send_now_font_variant, key_send_now_size, key_send_now_x, key_send_now_y, key_send_now_w, key_send_now_h, { r = key_send_now_r, g = key_send_now_g, b = key_send_now_b, a = key_send_now_a }, fade) then
        self:HideAtlasText("key_send_now")
    elseif key_send_now_dynamic then
        self:HideDynamicTextSlot("key_send_now")
        self:HideAtlasText("key_send_now")
        self:ShowFallbackTextWnd(self.key_send_now)
        self.key_send_now:SetText(key_send_now_text)
    elseif get_atlas_font_entry(key_send_now_size, "key_send_now_font_family") then
        self:ShowFallbackTextWnd(self.key_send_now)
        self.key_send_now:SetText("")
        if not self:RenderAtlasText("key_send_now", key_send_now_text, "key_send_now_font_family", key_send_now_size, key_send_now_x, key_send_now_y, key_send_now_w, key_send_now_h, key_send_now_color) then
            self.key_send_now:SetText(key_send_now_text)
        end
    else
        self:HideDynamicTextSlot("key_send_now")
        self:HideAtlasText("key_send_now")
        self:ShowFallbackTextWnd(self.key_send_now)
        self.key_send_now:SetText(key_send_now_text)
    end

    for index = 1, CUSTOM_LABEL_COUNT do
        local custom_label_value = get_str("custom_label_" .. tostring(index))
        if custom_label_value == "" then
            if self.custom_label[index] then
                self.custom_label[index]:SetText("")
            end
            self:HideDynamicTextSlot("custom_label_" .. tostring(index))
            self:HideAtlasText("custom_label_" .. tostring(index))
        else
            local suffix = tostring(index)
            local custom_font_key = "custom_label_" .. suffix .. "_font_family"
            local custom_size_key = "custom_label_" .. suffix .. "_size"
            local custom_label_size = get_text_size_level(custom_size_key)
            local custom_font_family = clamp_font_family_index(get_num(custom_font_key))
            local custom_font_variant = get_current_font_variant_index(custom_font_key)
            if self._custom_label_size_level[index] ~= custom_label_size or self._custom_label_font_family[index] ~= custom_font_family then
                local custom_font = font_countdown(custom_label_size, custom_font_key)
                if custom_font and self.custom_label[index] then
                    self.custom_label[index]:SetFont(custom_font)
                end
                self._custom_label_size_level[index] = custom_label_size
                self._custom_label_font_family[index] = custom_font_family
            end

            local custom_label_scale = text_size_scale(custom_label_size, custom_font_key)
            local custom_label_width = math.max(1, CUSTOM_LABEL_BASE_WIDTH * custom_label_scale)
            local custom_label_height = math.max(1, CUSTOM_LABEL_BASE_HEIGHT * custom_label_scale)
            local custom_label_alpha = clamp(get_num("custom_label_" .. suffix .. "_alpha"), 0, 100)
            local custom_r = clamp(get_num("custom_label_" .. suffix .. "_r"), 0, 255)
            local custom_g = clamp(get_num("custom_label_" .. suffix .. "_g"), 0, 255)
            local custom_b = clamp(get_num("custom_label_" .. suffix .. "_b"), 0, 255)
            local custom_a = math.floor(custom_label_alpha * 255 / 100 + 0.5)
            local custom_label_color = GetARGB(math.floor(custom_label_alpha * fade * 255 / 100 + 0.5), custom_r, custom_g, custom_b)
            local custom_label_window = self:GetCustomLabelWindow(index)
            local custom_label_x = cx + get_num("custom_label_" .. tostring(index) .. "_x") - custom_label_width / 2
            local custom_label_y = cy + get_num("custom_label_" .. tostring(index) .. "_y") - custom_label_height / 2
            custom_label_window:SetWndPos(vector2():set(custom_label_x, custom_label_y))
            custom_label_window:SetWndSize(vector2():set(custom_label_width, custom_label_height))
            custom_label_window:SetTextColor(custom_label_color)
            local custom_family_data = get_current_font_family(custom_font_key)
            local custom_dynamic = can_render_dynamic_text(custom_family_data, custom_font_variant)
            if self:RenderDynamicTextSlot("custom_label_" .. suffix, custom_label_window, custom_label_value, custom_family_data, custom_font_variant, custom_label_size, custom_label_x, custom_label_y, custom_label_width, custom_label_height, { r = custom_r, g = custom_g, b = custom_b, a = custom_a }, fade) then
                self:HideAtlasText("custom_label_" .. suffix)
            elseif custom_dynamic then
                self:HideDynamicTextSlot("custom_label_" .. suffix)
                self:HideAtlasText("custom_label_" .. suffix)
                self:ShowFallbackTextWnd(custom_label_window)
                custom_label_window:SetText(custom_label_value)
            elseif get_atlas_font_entry(custom_label_size, custom_font_key) then
                self:ShowFallbackTextWnd(custom_label_window)
                custom_label_window:SetText("")
                if not self:RenderAtlasText("custom_label_" .. suffix, custom_label_value, custom_font_key, custom_label_size, custom_label_x, custom_label_y, custom_label_width, custom_label_height, custom_label_color) then
                    custom_label_window:SetText(custom_label_value)
                end
            else
                self:HideDynamicTextSlot("custom_label_" .. suffix)
                self:HideAtlasText("custom_label_" .. suffix)
                self:ShowFallbackTextWnd(custom_label_window)
                custom_label_window:SetText(custom_label_value)
            end
        end
    end

    local adaptation = transition_countdown_adaptation
    if adaptation and adaptation.apply_overlay_layout then
        pcall(adaptation.apply_overlay_layout, self, self._adaptation_context, {
            center_x = cx,
            center_y = cy,
            correction = corr,
            fade = fade,
        })
    end
end

function STACCountdownOverlay:Update()
    CUIScriptWnd.Update(self)
    if not self:UpdateFade() then return end

    if self.preview_text then
        local preview_image_key = self.preview_image_key or "image_index"
        local preview_image = get_image_entry_by_key(preview_image_key, defaults[preview_image_key])
        local preview_profile = preview_image_key == "success_image_index" and "success_image" or "image"
        self:SetPanelImage(preview_image, preview_profile)
        self:ApplyLayout(self.preview_text)
    elseif self.fixed_text ~= nil then
        self:ApplyLayout(self.fixed_text)
    elseif active and active.remaining_text then
        self:ApplyLayout(active.remaining_text)
    elseif self._fade_mode == -1 then
        self:ApplyLayout(self._last_layout_text)
    end
end

local function update_overlay_text(text)
    if not active then return end
    active.remaining_text = text

    if active.overlay and STACCountdownOverlay.IsReady(active.overlay) then
        STACCountdownOverlay.ApplyLayout(active.overlay, text)
    end
end

local function destroy_retry_overlay()
    if retry_session and retry_session.overlay then
        pcall(function() retry_session.overlay:Destroy() end)
        retry_session.overlay = nil
    end
end

local function cancel_countdown()
    if not active then return end

    local overlay = active.overlay
    active.overlay = nil
    active = nil

    if overlay then
        pcall(function() overlay:Destroy() end)
    end
end

local function call_current_ok(wnd)
    if not wnd then return end
    local cls = ui_sr_teleport and ui_sr_teleport.msg_box_ui
    local ok_func = cls and cls.OnMsgOk
    if not ok_func then return end

    wnd.__stac_timer_finished = true
    pcall(ok_func, wnd)
    wnd.__stac_timer_finished = nil
end

local function retry_transition_update()
    if not retry_session then return true end

    if device and device().is_paused and device():is_paused() then
        return false
    end

    local inside = actor_inside_restrictor(retry_session)
    if not inside then
        destroy_retry_overlay()
        retry_session = nil
        return true
    end

    if not retry_session.wnd then
        destroy_retry_overlay()
        retry_session = nil
        return true
    end

    hide_transition_ui(retry_session.wnd)
    call_current_ok(retry_session.wnd)
    return false
end

local function start_transition_retry(session, wnd, overlay)
    if not CreateTimeEvent or not session or not wnd then return end

    retry_session = {
        wnd = wnd,
        restrictor_id = session.restrictor_id,
        restrictor_name = session.restrictor_name,
        overlay = overlay,
    }

    local inside = actor_inside_restrictor(retry_session)
    if not inside then
        destroy_retry_overlay()
        retry_session = nil
        return
    end

    CreateTimeEvent("safe_transition_auto_countdown", "stac_transition_retry", 1, retry_transition_update)
end

local function finish_countdown()
    if not active then return end

    local session = active
    local wnd = active.wnd
    local overlay = active.overlay

    active.overlay = nil
    hide_transition_ui(wnd)
    active = nil

    if overlay and STACCountdownOverlay.IsReady(overlay) then
        overlay.fixed_text = ""
        STACCountdownOverlay.SetPanelImage(overlay, get_image_entry_by_key("success_image_index", defaults.success_image_index), "success_image")
        STACCountdownOverlay.ApplyLayout(overlay, "")
    end

    call_current_ok(wnd)
    start_transition_retry(session, wnd, overlay)
end

local function on_key_press(key)
    if not active then return end
    if tonumber(key) ~= math.floor(get_num("key_send_now") + 0.5) then return end

    active.elapsed_ms = active.duration_ms
    finish_countdown()
end

local function countdown_update()
    if not active then return true end

    if device and device().is_paused and device():is_paused() then
        update_overlay_text(format_remaining(active.duration_ms - active.elapsed_ms))
        active.last_time = time_global()
        return false
    end

    if not actor_inside_restrictor(active) then
        cancel_countdown()
        return true
    end

    local now = time_global()
    local dt = now - (active.last_time or now)
    active.last_time = now

    if dt < 0 or dt > 500 then dt = 0 end

    active.elapsed_ms = active.elapsed_ms + dt
    local remaining = active.duration_ms - active.elapsed_ms

    if remaining <= 0 then
        finish_countdown()
        return true
    end

    update_overlay_text(format_remaining(remaining))
    return false
end

local function start_countdown(wnd)
    if not get_bool("enabled") then return false end
    if not wnd then return false end

    if wnd.disable_msg or wnd.__stc_disable_msg then return false end

    if active then
        if not actor_inside_restrictor(active) then
            cancel_countdown()
        else
            hide_transition_ui(wnd)
            return true
        end
    end

    local duration = get_num("duration")
    local adaptation_context = nil
    local adaptation = transition_countdown_adaptation
    if adaptation and adaptation.get_countdown_context then
        local context_ok, context = pcall(adaptation.get_countdown_context, wnd, duration)
        if context_ok and type(context) == "table" then
            adaptation_context = context
            duration = tonumber(context.duration) or duration
        end
    end
    if duration <= 0 then
        hide_transition_ui(wnd)
        call_current_ok(wnd)
        return true
    end

    active = {
        wnd = wnd,
        restrictor_id = wnd.__stc_restrictor_id,
        restrictor_name = wnd.__stc_restrictor_name or wnd.name,
        duration_ms = math.floor(duration * 1000),
        elapsed_ms = 0,
        last_time = time_global(),
        overlay = nil,
        remaining_text = nil,
        adaptation_context = adaptation_context,
    }

    hide_transition_ui(wnd)

    local ok, overlay = pcall(function() return STACCountdownOverlay() end)
    if ok and overlay and STACCountdownOverlay.IsReady(overlay) then
        overlay._adaptation_context = active.adaptation_context
        active.overlay = overlay
    end

    update_overlay_text(format_remaining(active.duration_ms))

    local action_id = "stac_timer_" .. tostring(time_global())
    CreateTimeEvent("safe_transition_auto_countdown", action_id, 0, countdown_update)
    return true
end

local function make_init_wrapper(old_func)
    local function wrapped(self, obj, disable_msg, item, ...)
        self.__stc_restrictor_id = safe_obj_id(obj)
        self.__stc_restrictor_name = safe_obj_name(obj)
        self.__stc_disable_msg = disable_msg
        return old_func(self, obj, disable_msg, item, ...)
    end
    patched_inits[wrapped] = true
    return wrapped
end

local function make_init_controls_wrapper(old_func)
    local function wrapped(self, ...)
        local r = old_func(self, ...)

        start_countdown(self)
        return r
    end
    patched_init_controls[wrapped] = true
    return wrapped
end

local function try_patch()
    local cls = ui_sr_teleport and ui_sr_teleport.msg_box_ui
    if not (cls and cls.__init and cls.InitControls) then return false end

    if not patched_inits[cls.__init] then
        cls.__init = make_init_wrapper(cls.__init)
    end

    if not patched_init_controls[cls.InitControls] then
        cls.InitControls = make_init_controls_wrapper(cls.InitControls)
    end

    return patched_inits[cls.__init] and patched_init_controls[cls.InitControls]
end

function init(force_image_refresh)
    append_adaptation_defaults()
    set_default_font_family_settings()
    load_runtime_images(force_image_refresh == true)
    load_user_config_once()
    normalize_text_size_settings()
    normalize_font_variant_settings()
    register_user_config_callback()
    local runtime = get_ttf_runtime()
    if runtime and runtime.is_ready then
        pcall(runtime.is_ready)
    end
    if patch_started then
        if RegisterScriptCallback and not key_callback_registered then
            RegisterScriptCallback("on_key_press", on_key_press)
            key_callback_registered = true
        end
        return
    end

    if not CreateTimeEvent then
        try_patch()
        return
    end

    patch_started = true

    if RegisterScriptCallback and not key_callback_registered then
        RegisterScriptCallback("on_key_press", on_key_press)
        key_callback_registered = true
    end

    CreateTimeEvent("safe_transition_auto_countdown", "stac_patch_watch", 0.5, function()
        patch_attempts = patch_attempts + 1
        if try_patch() then return true end
        return patch_attempts > 120
    end)
end

local function append_custom_label_live_commands(commands, index)
    local prefix = "custom_label_" .. tostring(index)
    local name_prefix = "ui_mcm_transition_countdown_universal_" .. prefix
    commands[#commands + 1] = { type = "line" }
    commands[#commands + 1] = { type = "custom_label_input", key = prefix, name = name_prefix, label_index = index }
    commands[#commands + 1] = { key = prefix .. "_x", name = name_prefix .. "_x", min = -512, max = 512, step = 1, dp = 0, is_coord = true }
    commands[#commands + 1] = { key = prefix .. "_y", name = name_prefix .. "_y", min = -300, max = 300, step = 1, dp = 0, is_coord = true }
    commands[#commands + 1] = { key = prefix .. "_font_family", name = name_prefix .. "_font_family", min = 0, max = #FONT_FAMILIES - 1, step = 1, dp = 0, is_font = true, variant_key = prefix .. "_font_variant" }
    commands[#commands + 1] = { key = prefix .. "_font_variant", name = name_prefix .. "_font_variant", min = 0, max = 0, step = 1, dp = 0, is_font_variant = true, font_key = prefix .. "_font_family" }
    commands[#commands + 1] = { key = prefix .. "_size", name = name_prefix .. "_size", min = TEXT_SIZE_MIN_PERCENT, max = TEXT_SIZE_MAX_PERCENT, step = 1, dp = 0, is_text_size = true }
    commands[#commands + 1] = { key = prefix .. "_r", name = name_prefix .. "_r", min = 0, max = 255, step = 1, dp = 0 }
    commands[#commands + 1] = { key = prefix .. "_g", name = name_prefix .. "_g", min = 0, max = 255, step = 1, dp = 0 }
    commands[#commands + 1] = { key = prefix .. "_b", name = name_prefix .. "_b", min = 0, max = 255, step = 1, dp = 0 }
    commands[#commands + 1] = { key = prefix .. "_alpha", name = name_prefix .. "_alpha", min = 0, max = 100, step = 1, dp = 0, is_percent = true }
end

