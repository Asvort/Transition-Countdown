local adaptation_live_commands_added = false

local function append_adaptation_live_commands()
    if adaptation_live_commands_added then return end
    local adaptation = transition_countdown_adaptation
    if adaptation and adaptation.append_live_commands then
        local ok = pcall(adaptation.append_live_commands, live_commands)
        adaptation_live_commands_added = ok
    end
end

local function level_present()
    return level and level.present and level.present()
end

local function live_round(command, value)
    if command.is_bool then
        return (tonumber(value) or 0) >= 0.5 and 1 or 0
    end
    if command.is_image then
        load_runtime_images(false)
        local image_max = math.max(0, #PANEL_IMAGES - 1)
        local image_index = math.floor((tonumber(value) or defaults[command.key] or 0) + 0.5)
        return clamp(image_index, 0, image_max)
    end
    if command.is_text_size then
        return text_size_level(value, get_font_family_key_for_size_key(command.key))
    end
    if command.is_font_variant then
        return clamp_font_variant_index(value, command.font_key)
    end
    if command.is_font then
        return clamp_font_family_index(value)
    end
    local result = tonumber(value) or 0
    if command.step and command.step > 0 then
        result = command.min + math.floor(((result - command.min) / command.step) + 0.5 + 0.000000001) * command.step
    end
    result = clamp(result, command.min, command.max)
    if command.is_coord and math.abs(result) < command.step then
        result = 0
    end

    local mult = 10 ^ (command.dp or 0)
    return math.floor(result * mult + 0.5 + 0.000000001) / mult
end

local function live_get(command)
    if command.is_bool then
        return get_bool(command.key) and 1 or 0
    end
    if command.is_text_size then
        return get_text_size_level(command.key)
    end
    if command.is_font_variant then
        return clamp_font_variant_index(get_num(command.key), command.font_key)
    end
    if command.is_font then
        return clamp_font_family_index(get_num(command.key))
    end
    return get_num(command.key)
end

local function live_set(command, value)
    if ui_mcm and ui_mcm.set then
        ui_mcm.set(mcm_path(command.key), command.is_bool and value == 1 or value)
        mark_user_config_dirty()
        if command.is_font then
            if command.variant_key then ui_mcm.set(mcm_path(command.variant_key), 0) end
            normalize_font_variant_settings()
            normalize_text_size_settings()
        end
    end
end

local function translate(key)
    if game and game.translate_string then
        local ok, text = pcall(game.translate_string, key)
        if ok and text and text ~= "" then return text end
    end
    return key
end

local function read_edit_box_text(control)
    if not control then return "" end
    local text_control_ok, text_control = pcall(function() return control:TextControl() end)
    if text_control_ok and text_control then
        local text_ok, text = pcall(function() return text_control:GetText() end)
        if text_ok then return tostring(text or "") end
    end
    local text_ok, text = pcall(function() return control:GetText() end)
    if text_ok then return tostring(text or "") end
    return ""
end

local function is_transition_countdown_mcm_path(path)
    local path_text = tostring(path or "")
    return path_text == MOD_ID or string.sub(path_text, 1, #MOD_ID + 1) == MOD_ID .. "/"
end

local function format_mcm_track_value(path, option, value)
    if not is_transition_countdown_mcm_path(path) then
        return tostring(value)
    end

    local number = tonumber(value)
    if number == nil then
        return tostring(value)
    end

    local option_name = tostring(option or "")
    local option_suffix = string.sub(option_name, -2)
    if is_tenth_step_setting(option_name) then
        return string.format("%g %s", number, translate("ui_mcm_transition_countdown_unit_seconds"))
    end
    if string.sub(option_name, -6) == "_alpha"
        or string.sub(option_name, -6) == "_scale"
        or string.sub(option_name, -5) == "_size" then
        local percent = number
        if string.sub(option_name, -6) == "_scale" then
            percent = number * 100
        end
        return string.format("%g%%", percent)
    end
    if option_suffix == "_x" or option_suffix == "_y" then
        return string.format("%g px", number)
    end
    return tostring(value)
end

local function patch_mcm_track_value_format()
    local mcm_class = ui_mcm and ui_mcm.UI_MCM
    if not mcm_class or mcm_class._transition_countdown_track_format_patched then return end

    local original_register_track = mcm_class.Register_Track
    local original_callback_track = mcm_class.Callback_Track
    if type(original_register_track) ~= "function" or type(original_callback_track) ~= "function" then return end

    mcm_class.Register_Track = function(mcm_self, xml, handler, path, option, attributes, flags)
        local row_height = original_register_track(mcm_self, xml, handler, path, option, attributes, flags)
        if is_transition_countdown_mcm_path(path) and (not attributes or not attributes.no_str) then
            for _, track in pairs(mcm_self._Track or {}) do
                if track.path == path and track.opt == option and track.txt then
                    track.txt:SetText(format_mcm_track_value(path, option, track.value))
                    break
                end
            end
        end
        return row_height
    end

    mcm_class.Callback_Track = function(mcm_self, control, path, option, attributes, value)
        local result = original_callback_track(mcm_self, control, path, option, attributes, value)
        if is_transition_countdown_mcm_path(path) and (not attributes or not attributes.no_str) then
            control:SetText(format_mcm_track_value(path, option, value))
        end
        return result
    end

    mcm_class._transition_countdown_track_format_patched = true
end

local function live_label(command, value)
    if command.is_bool then
        return translate(value == 1 and "ui_mcm_transition_countdown_yes" or "ui_mcm_transition_countdown_no")
    end
    if command.is_image then
        return get_image_name_by_index(value, defaults[command.key])
    end
    if command.is_font then
        return get_font_family_name_by_index(value)
    end
    if command.is_font_variant then
        return get_font_variant_name(command.font_key, value)
    end
    if command.is_coord then
        return string.format("%d px", math.floor(value + 0.5))
    end
    if command.is_seconds then
        return string.format("%.1f %s", value, translate("ui_mcm_transition_countdown_unit_seconds"))
    end
    if command.is_text_size then
        local font_key = get_font_family_key_for_size_key(command.key)
        return string.format("%d%%", math.floor(text_size_scale(value, font_key) * 100 + 0.5))
    end
    if command.is_scale then
        return string.format("%d%%", math.floor(value * 100 + 0.5))
    end
    if command.is_percent then
        return string.format("%d%%", math.floor(value + 0.5))
    end
    if command.dp and command.dp > 0 then
        return string.format("%." .. command.dp .. "f", value)
    end
    return string.format("%d", math.floor(value + 0.5))
end

local function live_max(command)
    if command.is_image then
        load_runtime_images()
        return math.max(0, #PANEL_IMAGES - 1)
    end
    if command.is_font then
        return math.max(0, #FONT_FAMILIES - 1)
    end
    if command.is_font_variant then
        return math.max(0, get_font_variant_count(command.font_key) - 1)
    end
    if command.is_text_size then
        return get_font_size_count(get_font_family_key_for_size_key(command.key))
    end
    return command.max
end

local function close_mcm_dialog(mcm_self)
    if not mcm_self then return end
    if mcm_self.On_Cancel then
        pcall(function() mcm_self:On_Cancel() end)
    elseif mcm_self.OnButton_Cancel then
        pcall(function() mcm_self:OnButton_Cancel() end)
    end
end

local function start_live_config()
    append_adaptation_live_commands()
    init(true)
    if exec_console_cmd then pcall(exec_console_cmd, "main_menu off") end
    if not STAC_CONFIG_GUI then STAC_CONFIG_GUI = STACConfigEdit() end
    if STAC_CONFIG_GUI and not STAC_CONFIG_GUI:IsShown() then
        STAC_CONFIG_GUI:ShowDialog(false)
        if Register_UI then pcall(Register_UI, "STACConfigEdit", "transition_countdown") end
        if not STAC_CONFIG_PREVIEW then
            local ok, preview = pcall(function() return STACCountdownOverlay() end)
            if ok and preview and STACCountdownOverlay.IsReady(preview) then
                preview.preview_text = format_remaining(get_num("duration") * 1000)
                preview.preview_image_key = "image_index"
                STAC_CONFIG_PREVIEW = preview
            end
        end
        if STAC_CONFIG_PREVIEW then
            STAC_CONFIG_PREVIEW.preview_text = format_remaining(get_num("duration") * 1000)
            local adaptation = transition_countdown_adaptation
            if adaptation and adaptation.get_preview_context then
                local context_ok, context = pcall(adaptation.get_preview_context, get_num("duration"))
                if context_ok and type(context) == "table" then
                    STAC_CONFIG_PREVIEW._adaptation_context = context
                end
            end
        end
    end
end

local function open_live_config(mcm_self)
    close_mcm_dialog(mcm_self)
    start_live_config()
end

class "STACConfigEdit" (CUIScriptWnd)

function STACConfigEdit:__init() super()
    self:InitControls()
    if RegisterScriptCallback then
        RegisterScriptCallback("actor_on_net_destroy", self)
    end
end

function STACConfigEdit:actor_on_net_destroy()
    self:Close()
end

function STACConfigEdit:InitControls()
    self:SetWndRect(Frect():set(0, 0, UI_W, UI_H))
    self:SetAutoDelete(true)

    self.xml = CScriptXmlInit()
    local xml = self.xml
    local xml_root = "transition_countdown_config"
    xml:ParseFile("ui_transition_countdown.xml")

    self.dialog = xml:InitStatic(xml_root, self)
    self.frame = xml:InitFrame(xml_root .. ":frame", self.dialog)
    self.scroll = xml:InitScrollView(xml_root .. ":scroll", self.dialog)
    self.scroll:Clear()

    self.CustomLabelInput = {}
    self.CustomLabelApplyFrame = {}
    self.CustomLabelApplyBackground = {}
    self.CustomLabelApplyHighlight = {}
    self.CustomLabelApply = {}
    self.CustomLabelApplyIcon = {}

    self.Track = {}
    self.Value = {}
    self.Num = {}
    self.KeyBindButton = {}
    self.KeyBindText = {}

    for index = 1, #live_commands do
        local command = live_commands[index]
        local row
        if command.type == "line" then
            row = xml:InitStatic(xml_root .. ":divider", nil)
            local divider = xml:InitStatic(xml_root .. ":divider:line", row)
            divider:SetTextureColor(GetARGB(255, 200, 200, 200))
        elseif command.type == "info" then
            row = xml:InitStatic(xml_root .. ":st", nil)
            local label = xml:InitStatic(xml_root .. ":cap", row)
            label:TextControl():SetText(translate(command.name))
            local value = xml:InitTextWnd(xml_root .. ":num", row)
            value:SetText(tostring(command.value or ""))
        elseif command.type == "custom_label_input" then
            local label_index = command.label_index
            row = xml:InitStatic(xml_root .. ":st", nil)
            local label = xml:InitStatic(xml_root .. ":cap", row)
            label:TextControl():SetText(translate(command.name))

            local input_id = "custom_label_input_" .. tostring(label_index)
            local apply_id = "custom_label_apply_" .. tostring(label_index)
            self.CustomLabelInput[label_index] = xml:InitEditBox(xml_root .. ":input", row)
            self.CustomLabelInput[label_index]:SetText(get_str(command.key))
            self.CustomLabelApplyFrame[label_index] = xml:InitFrame(xml_root .. ":input_apply_frame", row)
            self.CustomLabelApplyBackground[label_index] = xml:InitStatic(xml_root .. ":input_apply_background", row)
            self.CustomLabelApplyHighlight[label_index] = xml:InitStatic(xml_root .. ":input_apply_highlight", row)
            self.CustomLabelApply[label_index] = xml:Init3tButton(xml_root .. ":input_apply", row)
            self.CustomLabelApplyIcon[label_index] = xml:InitStatic(xml_root .. ":input_apply_icon", self.CustomLabelApply[label_index])

            local aspect_correction = get_ui_aspect_correction()
            local button_height = 24
            local button_right = 639
            local button_width = button_height / aspect_correction
            local button_left = button_right - button_width
            local icon_height = 12
            local icon_width = icon_height / aspect_correction
            self.CustomLabelApplyFrame[label_index]:SetWndPos(vector2():set(button_left, 0))
            self.CustomLabelApplyFrame[label_index]:SetWndSize(vector2():set(button_width, button_height))
            self.CustomLabelApplyBackground[label_index]:SetWndPos(vector2():set(button_left, 0))
            self.CustomLabelApplyBackground[label_index]:SetWndSize(vector2():set(button_width, button_height))
            self.CustomLabelApplyHighlight[label_index]:SetWndPos(vector2():set(button_left, 0))
            self.CustomLabelApplyHighlight[label_index]:SetWndSize(vector2():set(button_width, button_height))
            self.CustomLabelApplyHighlight[label_index]:Show(false)
            self.CustomLabelApply[label_index]:SetWndPos(vector2():set(button_left, 0))
            self.CustomLabelApply[label_index]:SetWndSize(vector2():set(button_width, button_height))
            self.CustomLabelApplyIcon[label_index]:SetWndPos(vector2():set((button_width - icon_width) / 2, (button_height - icon_height) / 2))
            self.CustomLabelApplyIcon[label_index]:SetWndSize(vector2():set(icon_width, icon_height))

            self:Register(self.CustomLabelInput[label_index], input_id)
            self:Register(self.CustomLabelApply[label_index], apply_id)
            self:AddCallback(apply_id, ui_events.BUTTON_CLICKED, function(owner)
                owner:ApplyCustomLabel(label_index)
            end, self)
        elseif command.type == "key_bind" then
            local key_bind_index = index
            row = xml:InitStatic(xml_root .. ":st", nil)
            local label = xml:InitStatic(xml_root .. ":cap", row)
            label:TextControl():SetText(translate(command.name))
            xml:InitFrame(xml_root .. ":key_bind_frame", row)
            self.KeyBindText[index] = xml:InitStatic(xml_root .. ":key_bind_text", row)
            self.KeyBindButton[index] = xml:Init3tButton(xml_root .. ":key_bind_button", row)
            self.KeyBindText[index]:TextControl():SetText(get_key_name(live_get(command)))

            local key_bind_id = "key_bind_" .. tostring(index)
            self:Register(self.KeyBindButton[index], key_bind_id)
            self:AddCallback(key_bind_id, ui_events.BUTTON_CLICKED, function(owner)
                owner:BeginKeyBinding(key_bind_index)
            end, self)
        else
            row = xml:InitStatic(xml_root .. ":st", nil)
            local label = xml:InitStatic(xml_root .. ":cap", row)
            label:TextControl():SetText(translate(command.name))

            local value = live_get(command)
            self.Track[index] = xml:InitTrackBar(xml_root .. ":track", row)
            self.Track[index]:SetStep(command.step)
            self.Track[index]:SetOptFBounds(command.min, live_max(command))
            self.Num[index] = xml:InitTextWnd(xml_root .. ":num", row)
            value = live_round(command, value)
            self.Track[index]:SetFValue(value)
            self.Value[index] = value
            self.Num[index]:SetText(live_label(command, value))
        end

        self.scroll:AddWindow(row, true)
        row:SetAutoDelete(true)
    end
end

function STACConfigEdit:BeginKeyBinding(index)
    if self.KeyBindCapture and self.KeyBindText[self.KeyBindCapture] then
        local previous_command = live_commands[self.KeyBindCapture]
        self.KeyBindText[self.KeyBindCapture]:TextControl():SetText(get_key_name(live_get(previous_command)))
    end

    self.KeyBindCapture = index
    self.KeyBindText[index]:TextControl():SetText("<?>")
end

function STACConfigEdit:ApplyKeyBinding(index, key)
    local command = live_commands[index]
    if not command or command.type ~= "key_bind" then return end

    live_set(command, key)
    self.KeyBindText[index]:TextControl():SetText(get_key_name(key))
    self.KeyBindCapture = nil
    if STAC_CONFIG_PREVIEW then
        STACCountdownOverlay.ApplyLayout(STAC_CONFIG_PREVIEW, STAC_CONFIG_PREVIEW.preview_text or "")
    end
end

function STACConfigEdit:ApplyCustomLabel(index)
    local control = self.CustomLabelInput and self.CustomLabelInput[index]
    if not control then return end

    local value = read_edit_box_text(control)
    mcm_custom_label_save(index, value)
    control:SetText(value)
    mark_user_config_dirty()
    save_user_config()
    if STAC_CONFIG_PREVIEW then
        STACCountdownOverlay.ApplyLayout(STAC_CONFIG_PREVIEW, STAC_CONFIG_PREVIEW.preview_text or "")
    end
end

function STACConfigEdit:RefreshFontControls()
    for index = 1, #live_commands do
        local command = live_commands[index]
        if command.is_font or command.is_font_variant or command.is_text_size then
            if command.is_text_size or command.is_font_variant then
                self.Track[index]:SetOptFBounds(command.min, live_max(command))
            end

            local value = live_round(command, live_get(command))
            self.Track[index]:SetFValue(value)
            self.Value[index] = value
            self.Num[index]:SetText(live_label(command, value))
        end
    end
end

function STACConfigEdit:Update()
    CUIScriptWnd.Update(self)

    for label_index, control in pairs(self.CustomLabelApply) do
        self.CustomLabelApplyHighlight[label_index]:Show(control:IsCursorOverWindow())
    end

    for index, control in pairs(self.Track) do
        if control:IsCursorOverWindow() then
            local command = live_commands[index]
            local value = live_round(command, control:GetFValue())
            if value ~= self.Value[index] then
                self.Value[index] = value
                live_set(command, value)
                self.Num[index]:SetText(live_label(command, value))
                if command.is_font then
                    self:RefreshFontControls()
                end
                if STAC_CONFIG_PREVIEW then
                    STAC_CONFIG_PREVIEW.preview_text = format_remaining(get_num("duration") * 1000)
                    if command.image_profile then
                        local preview_key = command.image_profile == "success_image" and "success_image_index" or "image_index"
                        STAC_CONFIG_PREVIEW.preview_image_key = preview_key
                        STACCountdownOverlay.SetPanelImage(
                            STAC_CONFIG_PREVIEW,
                            get_image_entry_by_key(preview_key, defaults[preview_key]),
                            command.image_profile
                        )
                    end
                    STACCountdownOverlay.ApplyLayout(STAC_CONFIG_PREVIEW, STAC_CONFIG_PREVIEW.preview_text)
                end
                return
            end
        end
    end
end

function STACConfigEdit:OnKeyboard(dik, keyboard_action)
    if self.KeyBindCapture and keyboard_action == ui_events.WINDOW_KEY_PRESSED then
        if dik == DIK_keys.DIK_ESCAPE then
            self:ApplyKeyBinding(self.KeyBindCapture, -1)
            return true
        end

        local key_name = get_key_name(dik)
        if not KEY_BIND_BLOCKED_KEYS[dik] and not is_empty_key_name(key_name) then
            self:ApplyKeyBinding(self.KeyBindCapture, dik)
            return true
        end
    end

    local res = CUIScriptWnd.OnKeyboard(self, dik, keyboard_action)
    if res == false and keyboard_action == ui_events.WINDOW_KEY_PRESSED then
        if dik == DIK_keys.DIK_ESCAPE then
            self:Close()
        end
    end
    return res
end

function STACConfigEdit:Close()
    flush_user_config()
    if UnregisterScriptCallback then
        pcall(UnregisterScriptCallback, "actor_on_net_destroy", self)
    end
    if STAC_CONFIG_PREVIEW then
        pcall(function() STAC_CONFIG_PREVIEW:Destroy() end)
        STAC_CONFIG_PREVIEW = nil
    end
    self:HideDialog()
    self:Show(false)
    if Unregister_UI then pcall(Unregister_UI, "STACConfigEdit") end
    STAC_CONFIG_GUI = nil
end

local function patch_custom_label_inputs()
    local mcm_class = ui_mcm and ui_mcm.UI_MCM
    if not mcm_class or mcm_class._transition_countdown_input_patched then return end

    local original_register_input = mcm_class.Register_Input
    if type(original_register_input) ~= "function" then return end

    mcm_class.Register_Input = function(mcm_self, xml, handler, path, option, attributes, flags)
        if not is_transition_countdown_mcm_path(path) or not is_custom_label_key(option) then
            return original_register_input(mcm_self, xml, handler, path, option, attributes, flags)
        end

        local option_id = path .. "/" .. option
        local row_height = mcm_self:Register_Cap(xml, handler, option_id, attributes.hint)

        if flags and flags.apply_to_all and flags.group then
            mcm_self:Register_BtnAll(xml, handler, path, option, attributes, flags)
        end

        local control = xml:InitEditBox("elements:input", handler)
        if control:GetHeight() > row_height then
            row_height = control:GetHeight()
        end

        local value = mcm_self:GetValue(path, option, attributes, flags)
        control:SetText(value or "")

        local control_id = mcm_self:Stacker(path, option, attributes)
        mcm_self:Register(control, control_id)
        local function commit_custom_label()
            local committed = read_edit_box_text(control)
            mcm_self:CacheValue(path, option, committed, attributes)
            control:SetText(committed)
        end
        mcm_self:AddCallback(control_id, ui_events.EDIT_TEXT_COMMIT, commit_custom_label, mcm_self)

        return row_height
    end
    mcm_class._transition_countdown_input_patched = true
end

local function patch_configure_in_game_button()
    local mcm_class = ui_mcm and ui_mcm.UI_MCM
    if not mcm_class or mcm_class._transition_countdown_button_patched then return end

    local original_register_button = mcm_class.Register_Button
    if type(original_register_button) ~= "function" then return end

    mcm_class.Register_Button = function(mcm_self, xml, handler, path, option, attributes, flags)
        if option ~= "configure_in_game" or not is_transition_countdown_mcm_path(path) then
            return original_register_button(mcm_self, xml, handler, path, option, attributes, flags)
        end

        local frame = xml:InitFrame("elements:frame_button", handler)
        local control = xml:Init3tButton("elements:btn_button", handler)
        local caption = xml:InitStatic("elements:cap_button", handler)
        local button_width = 400
        local button_height = 30
        local button_x = math.floor((563 - button_width) / 2 + 0.5)
        local button_y = 5
        local function align_window(window)
            if not window then return end
            window:SetWndPos(vector2():set(button_x, button_y))
            window:SetWndSize(vector2():set(button_width, button_height))
            pcall(function() window:SetStretchTexture(true) end)
        end

        align_window(frame)
        align_window(control)
        align_window(caption)
        local caption_key = attributes.hint or "transition_countdown_configure_in_game"
        caption:TextControl():SetText(game.translate_string("ui_mcm_" .. caption_key))

        local control_id = mcm_self:Stacker(path, option, attributes)
        mcm_self:Register(control, control_id)
        local function on_button_clicked()
            mcm_self:Callback_Button(control, path, option, attributes)
        end
        mcm_self:AddCallback(control_id, ui_events.BUTTON_CLICKED, on_button_clicked, mcm_self)
        return button_y + button_height + 5
    end
    mcm_class._transition_countdown_button_patched = true
end

local function append_custom_label_mcm_options(options, index)
    local prefix = "custom_label_" .. tostring(index)
    local hint_prefix = "transition_countdown_universal_" .. prefix
    options[#options + 1] = { id = "divider_ui", type = "line" }
    options[#options + 1] = { id = prefix, type = "input", val = 0, def = defaults[prefix], hint = hint_prefix, curr = { mcm_custom_label_current, index }, functor = { mcm_custom_label_save, index } }
    options[#options + 1] = { id = prefix .. "_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults[prefix .. "_x"], hint = hint_prefix .. "_x" }
    options[#options + 1] = { id = prefix .. "_y", type = "track", val = 2, min = -300, max = 300, step = 1, def = defaults[prefix .. "_y"], hint = hint_prefix .. "_y" }
    options[#options + 1] = { id = prefix .. "_font_family", type = "list", val = 2, def = defaults[prefix .. "_font_family"], hint = hint_prefix .. "_font_family", content = { font_family_content }, no_str = true, functor = { custom_label_font_family_changed_functions[index] } }
    options[#options + 1] = { id = prefix .. "_font_variant", type = "list", val = 2, def = defaults[prefix .. "_font_variant"], hint = hint_prefix .. "_font_variant", content = { custom_label_font_variant_content_functions[index] }, no_str = true }
    options[#options + 1] = { id = prefix .. "_size", type = "track", val = 2, min = TEXT_SIZE_MIN_PERCENT, max = TEXT_SIZE_MAX_PERCENT, step = 1, def = defaults[prefix .. "_size"], hint = hint_prefix .. "_size" }
    options[#options + 1] = { id = prefix .. "_r", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults[prefix .. "_r"], hint = hint_prefix .. "_r" }
    options[#options + 1] = { id = prefix .. "_g", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults[prefix .. "_g"], hint = hint_prefix .. "_g" }
    options[#options + 1] = { id = prefix .. "_b", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults[prefix .. "_b"], hint = hint_prefix .. "_b" }
    options[#options + 1] = { id = prefix .. "_alpha", type = "track", val = 2, min = 0, max = 100, step = 1, def = defaults[prefix .. "_alpha"], hint = hint_prefix .. "_alpha" }
end

function on_mcm_load()
    patch_configure_in_game_button()
    patch_mcm_track_value_format()
    patch_custom_label_inputs()
    init(true)
    local mcm_options = {
        id = MOD_ID,
        gr = {
            { id = "main", sh = true, text = "ui_mcm_transition_countdown_universal_title", gr = {
                { id = "title", type = "slide", text = "ui_mcm_transition_countdown_universal_title", size = {512, 50}, spacing = 20 },
                { id = "enabled", type = "check", val = 1, def = defaults.enabled, hint = "transition_countdown_enabled" },
                { id = "divider_ui", type = "line" },
                { id = "configure_in_game", type = "button", functor_ui = { open_live_config }, precondition = { level_present }, hint = "transition_countdown_configure_in_game" },
                { id = "divider_ui", type = "line" },
                { id = "group_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults.group_x, hint = "transition_countdown_group_x" },
                { id = "group_y", type = "track", val = 2, min = -384, max = 384, step = 1, def = defaults.group_y, hint = "transition_countdown_group_y" },
                { id = "fade_time", type = "track", val = 2, min = 0, max = 2, step = 0.1, prec = 1, def = defaults.fade_time, hint = "transition_countdown_fade_time" },
                { id = "divider_ui", type = "line" },
                { id = "duration", type = "track", val = 2, min = 0, max = 60, step = 0.1, prec = 1, def = defaults.duration, hint = "transition_countdown_universal_duration" },
                { id = "decimals", type = "check", val = 1, def = defaults.decimals, hint = "transition_countdown_decimals" },
                { id = "timer_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults.timer_x, hint = "transition_countdown_universal_timer_x" },
                { id = "timer_y", type = "track", val = 2, min = -300, max = 300, step = 1, def = defaults.timer_y, hint = "transition_countdown_universal_timer_y" },
                { id = "timer_font_family", type = "list", val = 2, def = defaults.timer_font_family, hint = "transition_countdown_universal_timer_font_family", content = { font_family_content }, no_str = true, functor = { on_timer_font_family_changed } },
                { id = "timer_font_variant", type = "list", val = 2, def = defaults.timer_font_variant, hint = "transition_countdown_universal_timer_font_variant", content = { timer_font_variant_content }, no_str = true },
                { id = "timer_size", type = "track", val = 2, min = TEXT_SIZE_MIN_PERCENT, max = TEXT_SIZE_MAX_PERCENT, step = 1, def = defaults.timer_size, hint = "transition_countdown_universal_timer_size" },
                { id = "timer_r", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.timer_r, hint = "transition_countdown_universal_timer_r" },
                { id = "timer_g", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.timer_g, hint = "transition_countdown_universal_timer_g" },
                { id = "timer_b", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.timer_b, hint = "transition_countdown_universal_timer_b" },
                { id = "timer_alpha", type = "track", val = 2, min = 0, max = 100, step = 1, def = defaults.timer_alpha, hint = "transition_countdown_universal_timer_alpha" },
                { id = "divider_ui", type = "line" },
                { id = "image_index", type = "list", val = 2, def = defaults.image_index, hint = "transition_countdown_universal_image_index", content = { panel_image_content }, no_str = true },
                { id = "image_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults.image_x, hint = "transition_countdown_universal_image_x" },
                { id = "image_y", type = "track", val = 2, min = -384, max = 384, step = 1, def = defaults.image_y, hint = "transition_countdown_universal_image_y" },
                { id = "image_scale", type = "track", val = 2, min = IMAGE_SCALE_MIN, max = IMAGE_SCALE_MAX, step = 0.01, def = defaults.image_scale, hint = "transition_countdown_universal_image_scale" },
                { id = "image_r", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.image_r, hint = "transition_countdown_universal_image_r" },
                { id = "image_g", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.image_g, hint = "transition_countdown_universal_image_g" },
                { id = "image_b", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.image_b, hint = "transition_countdown_universal_image_b" },
                { id = "image_alpha", type = "track", val = 2, min = 0, max = 100, step = 1, def = defaults.image_alpha, hint = "transition_countdown_universal_image_alpha" },
                { id = "divider_ui", type = "line" },
                { id = "success_image_index", type = "list", val = 2, def = defaults.success_image_index, hint = "transition_countdown_universal_success_image_index", content = { panel_image_content }, no_str = true },
                { id = "success_image_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults.success_image_x, hint = "transition_countdown_universal_success_image_x" },
                { id = "success_image_y", type = "track", val = 2, min = -384, max = 384, step = 1, def = defaults.success_image_y, hint = "transition_countdown_universal_success_image_y" },
                { id = "success_image_scale", type = "track", val = 2, min = IMAGE_SCALE_MIN, max = IMAGE_SCALE_MAX, step = 0.01, def = defaults.success_image_scale, hint = "transition_countdown_universal_success_image_scale" },
                { id = "success_image_r", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.success_image_r, hint = "transition_countdown_universal_success_image_r" },
                { id = "success_image_g", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.success_image_g, hint = "transition_countdown_universal_success_image_g" },
                { id = "success_image_b", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.success_image_b, hint = "transition_countdown_universal_success_image_b" },
                { id = "success_image_alpha", type = "track", val = 2, min = 0, max = 100, step = 1, def = defaults.success_image_alpha, hint = "transition_countdown_universal_success_image_alpha" },
                { id = "divider_ui", type = "line" },
                { id = "key_send_now", type = "key_bind", val = 2, def = defaults.key_send_now, hint = "transition_countdown_universal_force_key" },
                { id = "key_send_now_x", type = "track", val = 2, min = -512, max = 512, step = 1, def = defaults.key_send_now_x, hint = "transition_countdown_universal_key_send_now_x" },
                { id = "key_send_now_y", type = "track", val = 2, min = -300, max = 300, step = 1, def = defaults.key_send_now_y, hint = "transition_countdown_universal_key_send_now_y" },
                { id = "key_send_now_font_family", type = "list", val = 2, def = defaults.key_send_now_font_family, hint = "transition_countdown_universal_key_send_now_font_family", content = { font_family_content }, no_str = true, functor = { on_key_send_now_font_family_changed } },
                { id = "key_send_now_font_variant", type = "list", val = 2, def = defaults.key_send_now_font_variant, hint = "transition_countdown_universal_key_send_now_font_variant", content = { key_send_now_font_variant_content }, no_str = true },
                { id = "key_send_now_size", type = "track", val = 2, min = TEXT_SIZE_MIN_PERCENT, max = TEXT_SIZE_MAX_PERCENT, step = 1, def = defaults.key_send_now_size, hint = "transition_countdown_universal_key_send_now_size" },
                { id = "key_send_now_r", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.key_send_now_r, hint = "transition_countdown_universal_key_send_now_r" },
                { id = "key_send_now_g", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.key_send_now_g, hint = "transition_countdown_universal_key_send_now_g" },
                { id = "key_send_now_b", type = "track", val = 2, min = 0, max = 255, step = 1, def = defaults.key_send_now_b, hint = "transition_countdown_universal_key_send_now_b" },
                { id = "key_send_now_alpha", type = "track", val = 2, min = 0, max = 100, step = 1, def = defaults.key_send_now_alpha, hint = "transition_countdown_universal_key_send_now_alpha" },
                },
            },
        },
    }

    local main_options = mcm_options.gr[1].gr
    for index = 1, CUSTOM_LABEL_COUNT do
        append_custom_label_mcm_options(main_options, index)
    end

    local adaptation = transition_countdown_adaptation
    if adaptation and adaptation.append_mcm_options then
        pcall(adaptation.append_mcm_options, mcm_options.gr, open_live_config, level_present, defaults.duration)
    end
    return mcm_options
end

init()
